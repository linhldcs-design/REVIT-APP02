<Window x:Class="RevitAPP.Views.SheetAlignWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Căn Chỉnh View Trong Sheets"
        Width="520" Height="560"
        MinWidth="460" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        FontFamily="{DynamicResource Font.Family}"
        FontSize="{DynamicResource Font.Size.Body}"
        Foreground="{DynamicResource Brush.Text}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RevitAPP;component/Resources/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{DynamicResource Spacing.Large}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,10"
                   Foreground="{DynamicResource Brush.TextSecondary}"
                   Text="Chọn các sheet cần căn chỉnh, đặt 1 sheet làm mẫu và chọn cặp trục neo. Các sheet còn lại sẽ được kéo sao cho giao 2 trục trùng vị trí trên giấy như sheet mẫu (kèm vị trí tên bản vẽ)."/>

        <!-- Danh sách sheet: tick chọn + chọn mẫu -->
        <Border Grid.Row="1" Background="{DynamicResource Brush.Surface}" CornerRadius="4"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" Padding="6">
            <ListBox ItemsSource="{Binding Sheets}"
                     Background="Transparent" BorderThickness="0"
                     Foreground="{DynamicResource Brush.Text}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Text}"
                                       Text="{Binding Display}"/>
                            <RadioButton Grid.Column="2" GroupName="MasterSheet" Content="Mẫu"
                                         VerticalAlignment="Center"
                                         IsChecked="{Binding IsMaster, Mode=OneWay}"
                                         Command="{Binding DataContext.SetMasterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                         CommandParameter="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Chọn cặp trục neo -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource Brush.Text}" Text="Trục neo A:"/>
            <ComboBox Grid.Column="1" Height="28"
                      ItemsSource="{Binding Grids}" SelectedItem="{Binding GridA}"/>
            <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource Brush.Text}" Text="Trục neo B:"/>
            <ComboBox Grid.Column="4" Height="28"
                      ItemsSource="{Binding Grids}" SelectedItem="{Binding GridB}"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Căn chỉnh" IsDefault="True" Width="100" Height="30" Margin="0,0,8,0"
                    Command="{Binding OkCommand}"/>
            <Button Content="Huỷ" IsCancel="True" Width="100" Height="30"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>
