<Window x:Class="RevitAPP.Views.ColumnRebarView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:RevitAPP.Views"
        Title="Vẽ Thép Cột"
        Width="1140" Height="640"
        MinWidth="960" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        FontFamily="{DynamicResource Font.Family}"
        FontSize="{DynamicResource Font.Size.Body}"
        Foreground="{DynamicResource Brush.Text}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RevitAPP;component/Resources/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <v:EnumMatchConverter x:Key="EnumMatch"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{DynamicResource Spacing.Large}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Style="{StaticResource TabControl.Standard}">

            <!-- ============ TAB 1: Theo tầng (master-detail) ============ -->
            <TabItem Header="Theo tầng">
                <Border Background="{DynamicResource Brush.Surface}" CornerRadius="0,4,4,4" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="290"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: danh sách tầng -->
                        <DockPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock DockPanel.Dock="Top" Text="Danh sách tầng" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"/>
                            <ListBox ItemsSource="{Binding Floors}" SelectedItem="{Binding SelectedFloor}"
                                     Background="{DynamicResource Brush.Background}" BorderBrush="{DynamicResource Brush.Border}"
                                     Foreground="{DynamicResource Brush.Text}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2,4">
                                            <TextBlock Text="{Binding LevelName}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.Text}"/>
                                            <TextBlock Text="{Binding SectionLabel}" FontSize="11"
                                                       Foreground="{DynamicResource Brush.TextSecondary}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>

                        <!-- CENTER: thiết lập tầng đang chọn -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0"
                                      DataContext="{Binding SelectedFloor}">
                            <StackPanel>
                                <TextBlock Text="Thiết lập thép tầng đang chọn" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Số thanh phương X" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,2"
                                             Text="{Binding BarsX, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Số thanh phương Y" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,2"
                                             Text="{Binding BarsY, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Đường kính thép chủ" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" Style="{StaticResource ComboBox.Standard}" Margin="0,2"
                                              ItemsSource="{Binding DataContext.BarTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="Display"
                                              SelectedItem="{Binding MainBarType, UpdateSourceTrigger=PropertyChanged}"/>

                                    <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource CheckBox.Standard}"
                                              Margin="0,6" Content="Dùng thép phụ (distribution)"
                                              IsChecked="{Binding UseDistributionBar}"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Đường kính thép phụ" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="4" Grid.Column="1" Style="{StaticResource ComboBox.Standard}" Margin="0,2"
                                              IsEnabled="{Binding UseDistributionBar}"
                                              ItemsSource="{Binding DataContext.BarTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="Display"
                                              SelectedItem="{Binding DistributionBarType, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Đường kính thép đai" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="5" Grid.Column="1" Style="{StaticResource ComboBox.Standard}" Margin="0,2"
                                              ItemsSource="{Binding DataContext.BarTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="Display"
                                              SelectedItem="{Binding StirrupType, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="K/c đai đầu/chân (mm)" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="6" Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,2"
                                             Text="{Binding SpacingEndMm, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="K/c đai thân (mm)" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="7" Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,2"
                                             Text="{Binding SpacingMidMm, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Chiều cao dầm (tự dò)" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="8" Grid.Column="1" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,2"
                                               Text="{Binding BeamDepthLabel}"/>
                                </Grid>

                                <TextBlock Text="Kiểu đai tiết diện" FontWeight="SemiBold" Margin="0,14,0,6"
                                           Foreground="{DynamicResource Brush.Text}"/>
                                <StackPanel>
                                    <RadioButton Style="{StaticResource RadioButton.Standard}" Content="Đai kín"
                                                 IsChecked="{Binding StirrupSectionType, Converter={StaticResource EnumMatch}, ConverterParameter=ClosedTie}"/>
                                    <RadioButton Style="{StaticResource RadioButton.Standard}" Content="Đai + móc chéo (crosstie)"
                                                 IsChecked="{Binding StirrupSectionType, Converter={StaticResource EnumMatch}, ConverterParameter=Crosstie}"/>
                                    <RadioButton Style="{StaticResource RadioButton.Standard}" Content="Đai tách rời"
                                                 IsChecked="{Binding StirrupSectionType, Converter={StaticResource EnumMatch}, ConverterParameter=Separated}"/>
                                </StackPanel>

                                <Button Style="{StaticResource Button.Secondary}" Content="Áp dụng cho tất cả tầng"
                                        HorizontalAlignment="Left" Margin="0,16,0,0"
                                        Command="{Binding DataContext.ApplyToAllCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBlock Text="{Binding Error}" Foreground="{DynamicResource Brush.Danger}"
                                           TextWrapping="Wrap" Margin="0,10,0,0"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- RIGHT: section preview + thông số -->
                        <Border Grid.Column="2" Padding="12" Background="{DynamicResource Brush.Background}" CornerRadius="4"
                                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Tiết diện" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"/>
                                <Border Background="{DynamicResource Brush.Surface}" CornerRadius="3" HorizontalAlignment="Center" Padding="6" Margin="0,0,0,12">
                                    <Canvas Width="250" Height="200">
                                        <Rectangle Canvas.Left="{Binding SectionRectLeft}" Canvas.Top="{Binding SectionRectTop}"
                                                   Width="{Binding SectionRectWidth}" Height="{Binding SectionRectHeight}"
                                                   Stroke="{DynamicResource Brush.TextSecondary}" StrokeThickness="1.5"/>
                                        <Rectangle Canvas.Left="{Binding LoopRectLeft}" Canvas.Top="{Binding LoopRectTop}"
                                                   Width="{Binding LoopRectWidth}" Height="{Binding LoopRectHeight}"
                                                   Stroke="{DynamicResource Brush.Accent}" StrokeThickness="1.5"/>
                                        <ItemsControl ItemsSource="{Binding PreviewDots}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                                    <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Ellipse Width="{Binding Size}" Height="{Binding Size}"
                                                             Stroke="{DynamicResource Brush.Text}" StrokeThickness="1">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCorner}" Value="True">
                                                                        <Setter Property="Fill" Value="{DynamicResource Brush.Accent}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                </Border>

                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Tổng thanh:" Margin="0,2,12,2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Foreground="{DynamicResource Brush.Text}" Text="{Binding TotalBarText}" Margin="0,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Diện tích As:" Margin="0,2,12,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource Brush.Text}" Text="{Binding AreaText}" Margin="0,2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Hàm lượng μ:" Margin="0,2,12,2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Foreground="{DynamicResource Brush.Accent}" FontWeight="SemiBold" Text="{Binding RatioText}" Margin="0,2"/>
                                </Grid>
                                <TextBlock Text="● góc (thép chủ)   ○ giữa (thép phụ)" FontSize="11"
                                           Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ============ TAB 2: Móng / Thép chờ ============ -->
            <TabItem Header="Móng (thép chờ)">
                <Border Background="{DynamicResource Brush.Surface}" CornerRadius="0,4,4,4" Padding="20">
                    <StackPanel>
                        <CheckBox Style="{StaticResource CheckBox.Standard}" FontWeight="SemiBold"
                                  Content="Bật thép chờ móng (starter bar)" IsChecked="{Binding FoundationEnabled}"/>

                        <Grid Width="380" HorizontalAlignment="Left" Margin="0,16,0,0"
                              IsEnabled="{Binding FoundationEnabled}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Hm — đoạn cắm xuống móng (mm)" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,3"
                                     Text="{Binding FoundationHmMm, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Lb — chân ngang ở đáy móng (mm)" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,3"
                                     Text="{Binding FoundationLbMm, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <TextBlock Text="Hướng bẻ chân" FontWeight="SemiBold" Margin="0,18,0,6"
                                   Foreground="{DynamicResource Brush.Text}"/>
                        <StackPanel IsEnabled="{Binding FoundationEnabled}">
                            <RadioButton Style="{StaticResource RadioButton.Standard}" Content="Phải (+X)"
                                         IsChecked="{Binding FoundationDirection, Converter={StaticResource EnumMatch}, ConverterParameter=Right}"/>
                            <RadioButton Style="{StaticResource RadioButton.Standard}" Content="Trái (−X)"
                                         IsChecked="{Binding FoundationDirection, Converter={StaticResource EnumMatch}, ConverterParameter=Left}"/>
                            <RadioButton Style="{StaticResource RadioButton.Standard}" Content="Lên (+Y)"
                                         IsChecked="{Binding FoundationDirection, Converter={StaticResource EnumMatch}, ConverterParameter=Up}"/>
                            <RadioButton Style="{StaticResource RadioButton.Standard}" Content="Xuống (−Y)"
                                         IsChecked="{Binding FoundationDirection, Converter={StaticResource EnumMatch}, ConverterParameter=Down}"/>
                            <CheckBox Style="{StaticResource CheckBox.Standard}" Margin="0,8,0,0"
                                      Content="Bẻ chân 2 bên đối xứng (theo trục hướng đã chọn)"
                                      IsChecked="{Binding FoundationSplitBothSides}"/>
                        </StackPanel>

                        <TextBlock Text="Thép chờ bẻ chữ L: cắm XUỐNG móng đoạn Hm, foot Lb ngang ở đáy móng; đầu trên tự động vươn lên cột một đoạn nối chồng để lap với thép chủ."
                                   TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}"
                                   Margin="0,16,0,0" MaxWidth="440" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- ============ TAB 3: Đai (Stirrup) ============ -->
            <TabItem Header="Đai (Stirrup)">
                <Border Background="{DynamicResource Brush.Surface}" CornerRadius="0,4,4,4" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Rải đai toàn cột" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,12"/>

                        <Grid Width="420" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Khoảng cách tới đai đầu tiên (mm)" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,3"
                                     Text="{Binding DistanceToFirstStirrupMm, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Vùng gia cường tối thiểu l0 (mm)" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,3"
                                     Text="{Binding MinConfineZoneMm, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="l0 ≥ H thông thuỷ ÷ N" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,3"
                                     Text="{Binding ConfineClearanceDivisor, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <CheckBox Style="{StaticResource CheckBox.Standard}" Margin="0,14,0,0"
                                  Content="Rải đai xuyên qua dầm (bỏ cắt dưới đáy dầm)"
                                  IsChecked="{Binding SpreadThroughBeam}"/>

                        <TextBlock Text="Móc chéo (crosstie) — khi Kiểu đai = 'Đai + móc chéo'" FontWeight="SemiBold"
                                   Margin="0,14,0,6" Foreground="{DynamicResource Brush.Text}"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Style="{StaticResource RadioButton.Standard}" Margin="0,0,16,0" Content="Phương X (đứng)"
                                         IsChecked="{Binding CrosstieDirection, Converter={StaticResource EnumMatch}, ConverterParameter=X}"/>
                            <RadioButton Style="{StaticResource RadioButton.Standard}" Margin="0,0,16,0" Content="Phương Y (ngang)"
                                         IsChecked="{Binding CrosstieDirection, Converter={StaticResource EnumMatch}, ConverterParameter=Y}"/>
                            <RadioButton Style="{StaticResource RadioButton.Standard}" Content="Cả hai"
                                         IsChecked="{Binding CrosstieDirection, Converter={StaticResource EnumMatch}, ConverterParameter=Both}"/>
                        </StackPanel>

                        <CheckBox Style="{StaticResource CheckBox.Standard}" Margin="0,14,0,0"
                                  Content="Đặt đai gia cường trong vùng dầm/nút"
                                  IsChecked="{Binding ReinforceJoint}"/>
                        <Grid Width="420" HorizontalAlignment="Left" Margin="0,6,0,0" IsEnabled="{Binding ReinforceJoint}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Số đai gia cường trong dầm" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,3"
                                     Text="{Binding JointStirrupCount, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}"
                                   Margin="0,16,0,0" MaxWidth="440" HorizontalAlignment="Left"
                                   Text="Vùng gia cường đầu/chân cột l0 = max(H÷N, cạnh lớn tiết diện, l0 tối thiểu). Mặc định N=6, tối thiểu 450mm theo TCVN. Đai gia cường nút chỉ đặt khi KHÔNG rải xuyên dầm."/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- ============ TAB 4: Cài đặt ============ -->
            <TabItem Header="Cài đặt">
                <Border Background="{DynamicResource Brush.Surface}" CornerRadius="0,4,4,4" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Tùy chọn áp dụng toàn cột" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,12"/>
                        <Grid Width="380" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Lớp bê tông bảo vệ (mm)" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,3"
                                     Text="{Binding CoverMm, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Hệ số nối chồng (×d)" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,3"
                                     Text="{Binding LapFactor, UpdateSourceTrigger=PropertyChanged}"/>

                            <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource CheckBox.Standard}"
                                      Margin="0,8" Content="Nối thép so le (lap tại 2 vị trí)" IsChecked="{Binding StaggerLap}"/>
                        </Grid>

                        <TextBlock Text="Vị trí mối nối theo chiều cao tầng" FontWeight="SemiBold" Margin="0,20,0,8"
                                   Foreground="{DynamicResource Brush.Text}"/>
                        <RadioButton Style="{StaticResource RadioButton.Standard}" Content="Gần chân cột (cách đáy đoạn L)"
                                     IsChecked="{Binding LapPosition, Converter={StaticResource EnumMatch}, ConverterParameter=NearBottom}"/>
                        <RadioButton Style="{StaticResource RadioButton.Standard}" Content="Giữa cột (kháng chấn — mô-men nhỏ)"
                                     IsChecked="{Binding LapPosition, Converter={StaticResource EnumMatch}, ConverterParameter=Middle}"/>
                        <Grid Width="380" HorizontalAlignment="Left" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="L — cách đáy tầng (mm)" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,3"
                                     Text="{Binding LapDistanceFromBottomMm, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <TextBlock Text="Đỉnh cột (tầng trên cùng)" FontWeight="SemiBold" Margin="0,20,0,8"
                                   Foreground="{DynamicResource Brush.Text}"/>
                        <CheckBox Style="{StaticResource CheckBox.Standard}" Content="Bẻ móc 90° vào lõi tại đỉnh cột"
                                  IsChecked="{Binding TopHookBending}"/>
                        <Grid Width="380" HorizontalAlignment="Left" Margin="0,8,0,0" IsEnabled="{Binding TopHookBending}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Chiều dài móc đỉnh (mm)" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,3"
                                     Text="{Binding TopHookLengthMm, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <TextBlock Text="Bỏ chọn 'bẻ móc đỉnh' nếu cột còn nối tiếp lên tầng trên (để thép thẳng)."
                                   TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}"
                                   Margin="0,12,0,0" MaxWidth="420" HorizontalAlignment="Left"/>

                        <TextBlock Text="Vị trí nối thép" FontWeight="SemiBold" Margin="0,20,0,8"
                                   Foreground="{DynamicResource Brush.Text}"/>
                        <CheckBox Style="{StaticResource CheckBox.Standard}"
                                  Content="Uốn lệch (crank) thép tại vị trí nối để tránh đè thanh trên"
                                  IsChecked="{Binding CrankAtLap}"/>
                        <TextBlock Text="Bật: đoạn nối chồng uốn lệch vào lõi ~1 đường kính. Tắt: 2 thanh nối song song (thẳng)."
                                   TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}"
                                   Margin="0,8,0,0" MaxWidth="440" HorizontalAlignment="Left"/>

                        <TextBlock Text="Cột bóp/thu tiết diện (Bar Bending condition)" FontWeight="SemiBold" Margin="0,20,0,8"
                                   Foreground="{DynamicResource Brush.Text}"/>
                        <Grid Width="380" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Uốn vát nếu e ≤ (mm)" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,3"
                                     Text="{Binding BendIfOffsetLeMm, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Tỷ lệ dốc Hd/e ≥" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,3"
                                     Text="{Binding SlopeRatioHdOverE, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Width="380" HorizontalAlignment="Left" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource TextBlock.Label}" Text="Thép cột trên neo xuống nút (mm)" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource TextBox.Standard}" Margin="0,3"
                                     Text="{Binding JointAnchorDownMm, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <TextBlock Text="Khi bóp lớn (e > ngưỡng)" Margin="0,12,0,6"
                                   Foreground="{DynamicResource Brush.Text}"/>
                        <RadioButton Style="{StaticResource RadioButton.Standard}" Content="Hình 1 — Neo móc ngang tại sàn (cột trên thép riêng)"
                                     IsChecked="{Binding LargeStepMode, Converter={StaticResource EnumMatch}, ConverterParameter=AnchorAtSlab}"/>
                        <RadioButton Style="{StaticResource RadioButton.Standard}" Content="Hình 2 — Uốn vát liên tục lên cột trên"
                                     IsChecked="{Binding LargeStepMode, Converter={StaticResource EnumMatch}, ConverterParameter=CrankContinuous}"/>

                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}"
                                   Margin="0,8,0,0" MaxWidth="440" HorizontalAlignment="Left"
                                   Text="e ≤ ngưỡng → luôn uốn vát êm. e > ngưỡng → chọn Hình 1 (neo móc, cắt thép) hoặc Hình 2 (uốn vát dốc thoải liên tục) theo tiêu chuẩn áp dụng."/>

                        <TextBlock Text="Xuất schedule" FontWeight="SemiBold" Margin="0,20,0,8"
                                   Foreground="{DynamicResource Brush.Text}"/>
                        <CheckBox Style="{StaticResource CheckBox.Standard}"
                                  Content="Gán Partition = Mark cột cho thép (nhóm theo cột trong schedule/browser)"
                                  IsChecked="{Binding AddPartition}"/>
                    </StackPanel>
                </Border>
            </TabItem>

        </TabControl>

        <!-- Footer: preset (trái) + hành động (phải) -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Preset cấu hình -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Cấu hình:" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource Brush.Text}"/>
                <ComboBox Width="180" VerticalAlignment="Center"
                          ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}"
                          DisplayMemberPath="Name"
                          Background="{DynamicResource Brush.Background}"
                          BorderBrush="{DynamicResource Brush.Border}"
                          Foreground="{DynamicResource Brush.Text}"/>
                <Button Style="{StaticResource Button.Secondary}" Content="Xoá" Margin="6,0,0,0"
                        Command="{Binding DeletePresetCommand}"/>
                <TextBox Style="{StaticResource TextBox.Standard}" Width="150" Margin="16,0,0,0"
                         VerticalAlignment="Center"
                         Text="{Binding PresetName, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Style="{StaticResource Button.Secondary}" Content="Lưu cấu hình" Margin="6,0,0,0"
                        Command="{Binding SavePresetCommand}"/>
            </StackPanel>

            <!-- Vẽ / Huỷ -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource Button.Primary}" Content="Vẽ" IsDefault="True"
                        Margin="0,0,8,0" Command="{Binding DrawCommand}"/>
                <Button Style="{StaticResource Button.Secondary}" Content="Huỷ" IsCancel="True"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
