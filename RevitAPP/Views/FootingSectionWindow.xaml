<Window x:Class="RevitAPP.Views.FootingSectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Triển khai mặt cắt móng"
        Width="900" Height="640" MinWidth="780" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.Text}"
        FontFamily="{DynamicResource Font.Family}"
        FontSize="{DynamicResource Font.Size.Body}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RevitAPP;component/Resources/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="PanelCard" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Padding" Value="{DynamicResource Spacing.Medium}"/>
            </Style>
            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                <Setter Property="Margin" Value="0,4,0,4"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="{DynamicResource Spacing.Large}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Presets -->
        <Border Grid.Column="0" Margin="0,0,8,0" Style="{DynamicResource PanelCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="CẤU HÌNH ĐÃ LƯU" Style="{DynamicResource SectionHeader}"/>
                <TextBlock Grid.Row="1" Text="Tên cấu hình" Style="{DynamicResource FieldLabel}"/>
                <TextBox Grid.Row="2" Margin="0,0,0,8" Style="{DynamicResource TextBox.Standard}"
                         Text="{Binding SettingName, UpdateSourceTrigger=PropertyChanged}"/>
                <ListBox Grid.Row="3" Margin="0,0,0,8" ItemsSource="{Binding Presets}"
                         SelectedItem="{Binding SelectedPreset}" DisplayMemberPath="SettingName"
                         Background="{DynamicResource Brush.Background}" Foreground="{DynamicResource Brush.Text}"/>
                <WrapPanel Grid.Row="4" Margin="0,0,0,6">
                    <Button Content="Thêm" Command="{Binding AddPresetCommand}" Margin="0,0,4,4"
                            Style="{DynamicResource Button.Secondary}"/>
                    <Button Content="Cập nhật" Command="{Binding UpdatePresetCommand}" Margin="0,0,4,4"
                            Style="{DynamicResource Button.Secondary}"/>
                    <Button Content="Xoá" Command="{Binding DeletePresetCommand}" Margin="0,0,4,4"
                            Style="{DynamicResource Button.Secondary}"/>
                </WrapPanel>
                <WrapPanel Grid.Row="5">
                    <Button Content="Nhập..." Command="{Binding LoadPresetsCommand}" Margin="0,0,4,0"
                            Style="{DynamicResource Button.Secondary}"/>
                    <Button Content="Xuất..." Command="{Binding ExportPresetsCommand}"
                            Style="{DynamicResource Button.Secondary}"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Config -->
        <Border Grid.Column="1" Style="{DynamicResource PanelCard}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="MẶT CẮT / VIEW" Style="{DynamicResource SectionHeader}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tỉ lệ (1:n)" Style="{DynamicResource FieldLabel}"/>
                            <TextBox Style="{DynamicResource TextBox.Standard}"
                                     Text="{Binding ScaleText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Section Type" Style="{DynamicResource FieldLabel}"/>
                            <ComboBox Style="{DynamicResource ComboBox.Standard}" ItemsSource="{Binding SectionTypeOptions}"
                                      SelectedItem="{Binding SelectedSectionType}"/>
                            <TextBlock Text="View Template" Style="{DynamicResource FieldLabel}"/>
                            <ComboBox Style="{DynamicResource ComboBox.Standard}" ItemsSource="{Binding ViewTemplateOptions}"
                                      SelectedItem="{Binding SelectedViewTemplate}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Hướng mặt cắt" Style="{DynamicResource FieldLabel}"/>
                            <ComboBox Style="{DynamicResource ComboBox.Standard}" ItemsSource="{Binding DirectionOptions}"
                                      SelectedItem="{Binding SelectedDirection}"/>
                            <TextBlock Text="Vùng nhìn từ Level" Style="{DynamicResource FieldLabel}"/>
                            <ComboBox Style="{DynamicResource ComboBox.Standard}" ItemsSource="{Binding LevelOptions}"
                                      SelectedItem="{Binding SelectedViewBottomLevel}"/>
                            <TextBlock Text="Vùng nhìn đến Level" Style="{DynamicResource FieldLabel}"/>
                            <ComboBox Style="{DynamicResource ComboBox.Standard}" ItemsSource="{Binding LevelOptions}"
                                      SelectedItem="{Binding SelectedViewTopLevel}"/>
                            <TextBlock Text="Viewport Type" Style="{DynamicResource FieldLabel}"/>
                            <ComboBox Style="{DynamicResource ComboBox.Standard}" ItemsSource="{Binding ViewportTypeOptions}"
                                      SelectedItem="{Binding SelectedViewport}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="TAG THÉP" Style="{DynamicResource SectionHeader}" Margin="0,12,0,8"/>
                    <CheckBox Content="Tag thép đế móng" IsChecked="{Binding TagFooting}"
                              Style="{DynamicResource CheckBox.Standard}"/>
                    <ComboBox Style="{DynamicResource ComboBox.Standard}" ItemsSource="{Binding RebarTagOptions}"
                              SelectedItem="{Binding SelectedFootingTag}" IsEnabled="{Binding TagFooting}"/>
                    <CheckBox Content="Tag đai cổ móng" IsChecked="{Binding TagStirrup}" Margin="0,6,0,0"
                              Style="{DynamicResource CheckBox.Standard}"/>
                    <ComboBox Style="{DynamicResource ComboBox.Standard}" ItemsSource="{Binding RebarTagOptions}"
                              SelectedItem="{Binding SelectedStirrupTag}" IsEnabled="{Binding TagStirrup}"/>
                    <CheckBox Content="Tag thép chờ cột" IsChecked="{Binding TagStarter}" Margin="0,6,0,0"
                              Style="{DynamicResource CheckBox.Standard}"/>
                    <ComboBox Style="{DynamicResource ComboBox.Standard}" ItemsSource="{Binding RebarTagOptions}"
                              SelectedItem="{Binding SelectedStarterTag}" IsEnabled="{Binding TagStarter}"/>

                    <TextBlock Text="DIMENSION" Style="{DynamicResource SectionHeader}" Margin="0,12,0,8"/>
                    <CheckBox Content="Bật dimension" IsChecked="{Binding DimEnabled}"
                              Style="{DynamicResource CheckBox.Standard}"/>
                    <TextBlock Text="Loại DIM" Style="{DynamicResource FieldLabel}"/>
                    <ComboBox Style="{DynamicResource ComboBox.Standard}" ItemsSource="{Binding DimensionTypeOptions}"
                              SelectedItem="{Binding SelectedDimType}" IsEnabled="{Binding DimEnabled}"/>
                    <TextBlock Text="Khoảng cách DIM tới mép (mm)" Style="{DynamicResource FieldLabel}"/>
                    <TextBox Style="{DynamicResource TextBox.Standard}"
                             Text="{Binding DimOffsetText, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="BREAK LINE (CẮT CỘT)" Style="{DynamicResource SectionHeader}" Margin="0,12,0,8"/>
                    <CheckBox Content="Bật break line cắt cột" IsChecked="{Binding BreakLineEnabled}"
                              Style="{DynamicResource CheckBox.Standard}"/>
                    <ComboBox Style="{DynamicResource ComboBox.Standard}" ItemsSource="{Binding BreakLineOptions}"
                              SelectedItem="{Binding SelectedBreakLine}" IsEnabled="{Binding BreakLineEnabled}"/>

                    <TextBlock Text="SHEET ĐÍCH" Style="{DynamicResource SectionHeader}" Margin="0,12,0,8"/>
                    <TextBlock Text="Chọn sheet có sẵn" Style="{DynamicResource FieldLabel}"/>
                    <ComboBox Style="{DynamicResource ComboBox.Standard}" ItemsSource="{Binding ExistingSheetOptions}"
                              SelectedItem="{Binding SelectedExistingSheet}" DisplayMemberPath="Display"/>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Số hiệu" Style="{DynamicResource FieldLabel}"/>
                            <TextBox Style="{DynamicResource TextBox.Standard}"
                                     Text="{Binding SheetNumber, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tên sheet" Style="{DynamicResource FieldLabel}"/>
                            <TextBox Style="{DynamicResource TextBox.Standard}"
                                     Text="{Binding SheetName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Action buttons -->
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Huỷ" Command="{Binding CancelCommand}" Width="100" Margin="0,0,8,0"
                    Style="{DynamicResource Button.Secondary}"/>
            <Button Content="Tạo bản vẽ" Command="{Binding OkCommand}" Width="140"
                    Style="{DynamicResource Button.Primary}"/>
        </StackPanel>
    </Grid>
</Window>
