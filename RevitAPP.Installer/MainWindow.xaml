<Window x:Class="RevitAPP.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RevitAPP Installer" Width="620" Height="440"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource Brush.Background}" Foreground="{DynamicResource Brush.Text}"
        FontFamily="{DynamicResource Font.Family}" FontSize="{DynamicResource Font.Size.Body}">
    <Grid Margin="{DynamicResource Spacing.Medium}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="RevitAPP Installer" FontSize="26" FontWeight="SemiBold"/>
        <Border Grid.Row="1" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1" CornerRadius="5" Padding="16" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="BẢN QUYỀN" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding LicenseStatus}" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,6,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Đăng nhập Google" Command="{Binding SignInCommand}"
                        Style="{DynamicResource SecondaryButton}"/>
            </Grid>
        </Border>
        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="Phiên bản Revit" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding RevitYears}" SelectedItem="{Binding SelectedRevitYear}"
                      Height="32" Padding="8,4"/>
        </Grid>
        <Border Grid.Row="3" Background="{DynamicResource Brush.Accent}" CornerRadius="5" Padding="12"
                Margin="0,14,0,0" Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="{Binding UpdateNotice}" Foreground="White" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Cập nhật ngay" Command="{Binding InstallCommand}"
                        Style="{DynamicResource SecondaryButton}" Margin="12,0,0,0"/>
            </Grid>
        </Border>
        <Border Grid.Row="4" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1" CornerRadius="5" Padding="16" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="TRẠNG THÁI" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding InstalledRevitText}" Foreground="{DynamicResource Brush.TextSecondary}"
                           Margin="0,8,0,0"/>
                <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                <ProgressBar Height="5" Margin="0,16,0,0" IsIndeterminate="{Binding IsBusy}"/>
                <Button Content="Kiểm tra cập nhật" Command="{Binding CheckUpdatesCommand}"
                        IsEnabled="{Binding IsNotBusy}" Style="{DynamicResource SecondaryButton}"
                        HorizontalAlignment="Left" Margin="0,14,0,0"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Gỡ cài đặt" Command="{Binding UninstallCommand}" IsEnabled="{Binding IsNotBusy}"
                    Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="Cài đặt / Cập nhật" Command="{Binding InstallCommand}" IsEnabled="{Binding IsNotBusy}"
                    Style="{DynamicResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
