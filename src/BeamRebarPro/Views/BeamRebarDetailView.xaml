<Window
    x:Class="BeamRebarPro.Views.BeamRebarDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:viewModel="clr-namespace:BeamRebarPro.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance viewModel:BeamRebarDetailViewModel}"
    WindowStartupLocation="CenterScreen"
    Title="Beam Rebar"
    Height="700"
    Width="1280"
    Background="#F6F7F8">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="24" />
            <Setter Property="Width" Value="90" />
            <Setter Property="Margin" Value="0,0,16,8" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="24" />
            <Setter Property="Width" Value="90" />
            <Setter Property="Margin" Value="0,0,16,8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="RadioButton" x:Key="SettingTab">
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" BorderBrush="#D9DEE3"
                                BorderThickness="1" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D6F0E8" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0AAE94" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#0AAE94" Height="8" />

        <Grid DockPanel.Dock="Bottom" Margin="12,8">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#52606D"
                       VerticalAlignment="Center" HorizontalAlignment="Left" MaxWidth="700" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Toggle Section Image" Click="ToggleSection_Click" Padding="10,4" Margin="0,0,8,0" />
                <Button Content="Back" Click="Back_Click" Padding="16,4" Margin="0,0,8,0" />
                <Button Content="Ok" Click="Ok_Click" Padding="20,4" Margin="0,0,8,0" />
                <Button Content="Close" Click="Close_Click" Padding="16,4" />
            </StackPanel>
        </Grid>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="240" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Cột trái: 6 mục Setting -->
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Setting" FontWeight="Bold" Margin="0,0,0,8" />
                <RadioButton Style="{StaticResource SettingTab}" Content="Main Top Bar" IsChecked="True"
                             Command="{Binding SelectTabCommand}" CommandParameter="MainTopBar" />
                <RadioButton Style="{StaticResource SettingTab}" Content="Main Bot Bar"
                             Command="{Binding SelectTabCommand}" CommandParameter="MainBotBar" />
                <RadioButton Style="{StaticResource SettingTab}" Content="Add. Top Bar"
                             Command="{Binding SelectTabCommand}" CommandParameter="AddTopBar" />
                <RadioButton Style="{StaticResource SettingTab}" Content="Add. Bot Bar"
                             Command="{Binding SelectTabCommand}" CommandParameter="AddBotBar" />
                <RadioButton Style="{StaticResource SettingTab}" Content="Stirrup"
                             Command="{Binding SelectTabCommand}" CommandParameter="Stirrup" />
                <RadioButton Style="{StaticResource SettingTab}" Content="Anti bulge rebar"
                             Command="{Binding SelectTabCommand}" CommandParameter="AntiBulge" />
            </StackPanel>

            <!-- Vùng giữa/phải: form chi tiết theo tab -->
            <Border Grid.Row="0" Grid.Column="1" BorderBrush="#D9DEE3" BorderThickness="1" CornerRadius="3"
                    Background="White" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>

                    <!-- Rebar List -->
                    <DockPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock DockPanel.Dock="Top" Text="Rebar List" FontWeight="Bold" Margin="0,0,0,6" />
                        <Border DockPanel.Dock="Top" BorderBrush="#C7D0D9" BorderThickness="1,1,1,0" Padding="6,4">
                            <TextBlock Text="Rebar Name" HorizontalAlignment="Center" FontWeight="SemiBold" />
                        </Border>
                        <ListBox ItemsSource="{Binding RebarList}" SelectedItem="{Binding SelectedRebarListItem}" />
                    </DockPanel>

                    <!-- Rebar Info (Main bar form). ScrollViewer để form dài (Add Bot Bar) không che nút Add/Delete. -->
                    <ScrollViewer Grid.Column="1" Margin="0,0,12,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedTabTitle}" FontSize="15" FontWeight="Bold" Margin="0,0,0,12" />

                        <!-- Main Top/Bot Bar -->
                        <StackPanel Visibility="{Binding IsMainBarTab, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Diameter:" Style="{StaticResource FieldLabel}" Width="70" />
                                <ComboBox ItemsSource="{Binding DiameterOptions}" ItemStringFormat="'D'0" SelectedItem="{Binding MainDiameterMm}" />
                                <TextBlock Text="Number:" Style="{StaticResource FieldLabel}" Width="64" />
                                <ComboBox ItemsSource="{Binding NumberOptions}" SelectedItem="{Binding MainNumber}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Start Point:" Style="{StaticResource FieldLabel}" Width="70" />
                                <ComboBox ItemsSource="{Binding PointOptions}" SelectedItem="{Binding MainStartPoint}" />
                                <TextBlock Text="End Point:" Style="{StaticResource FieldLabel}" Width="64" />
                                <ComboBox ItemsSource="{Binding PointOptions}" SelectedItem="{Binding MainEndPoint}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Anchor Left:" Style="{StaticResource FieldLabel}" Width="70" />
                                <TextBox Text="{Binding AnchorLeftMm}" />
                                <TextBlock Text="Anchor Right:" Style="{StaticResource FieldLabel}" Width="64" />
                                <TextBox Text="{Binding AnchorRightMm}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Anchor X Left:" Style="{StaticResource FieldLabel}" Width="88" />
                                <TextBox Text="{Binding AnchorXLeftMm}" />
                                <TextBlock Text="Anchor X Right:" Style="{StaticResource FieldLabel}" Width="92" />
                                <TextBox Text="{Binding AnchorXRightMm}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Anchor Y:" Style="{StaticResource FieldLabel}" Width="70" />
                                <TextBox Text="{Binding TopBendDownLengthMm}" IsEnabled="{Binding DiagramHighlightTop}" />
                                <TextBlock Text="Position In Section:" Style="{StaticResource FieldLabel}" Width="112" />
                                <TextBox Text="{Binding MainPositionInSection}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Add Top/Bot Bar (thép gia cường) -->
                        <StackPanel Visibility="{Binding IsAddBarTab, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Layer:" Style="{StaticResource FieldLabel}" Width="70" />
                                <ComboBox ItemsSource="{Binding LayerOptions}" SelectedItem="{Binding AddLayer}" />
                                <TextBlock Text="Diameter:" Style="{StaticResource FieldLabel}" Width="64" />
                                <ComboBox ItemsSource="{Binding DiameterOptions}" ItemStringFormat="'D'0" SelectedItem="{Binding AddDiameterMm}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Start Point:" Style="{StaticResource FieldLabel}" Width="70" />
                                <ComboBox ItemsSource="{Binding PointOptions}" SelectedItem="{Binding AddStartPoint}" />
                                <TextBlock Text="End Point:" Style="{StaticResource FieldLabel}" Width="64" />
                                <ComboBox ItemsSource="{Binding PointOptions}" SelectedItem="{Binding AddEndPoint}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Start Type:" Style="{StaticResource FieldLabel}" Width="70" />
                                <ComboBox Width="120" ItemsSource="{Binding AddEndTypeOptions}" SelectedItem="{Binding AddStartType}" />
                                <TextBlock Text="End Type:" Style="{StaticResource FieldLabel}" Width="64" />
                                <ComboBox Width="120" ItemsSource="{Binding AddEndTypeOptions}" SelectedItem="{Binding AddEndType}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Left Ratio:" Style="{StaticResource FieldLabel}" Width="70" />
                                <TextBox Text="{Binding AddLeftRatio}" />
                                <TextBlock Text="Right Ratio:" Style="{StaticResource FieldLabel}" Width="80" />
                                <TextBox Text="{Binding AddRightRatio}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Left Length:" Style="{StaticResource FieldLabel}" Width="70" />
                                <TextBox Text="{Binding AddLeftLengthMm}" />
                                <TextBlock Text="Right Length:" Style="{StaticResource FieldLabel}" Width="80" />
                                <TextBox Text="{Binding AddRightLengthMm}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Visibility="{Binding DiagramHighlightTop, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="D Left:" Style="{StaticResource FieldLabel}" Width="70" />
                                <TextBox Text="{Binding AddDLeftMm}" />
                                <TextBlock Text="D Right:" Style="{StaticResource FieldLabel}" Width="80" />
                                <TextBox Text="{Binding AddDRightMm}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Visibility="{Binding DiagramHighlightBottom, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Anchor Left:" Style="{StaticResource FieldLabel}" Width="70" />
                                <TextBox Text="{Binding AddAnchorLeftMm}" />
                                <TextBlock Text="Anchor Right:" Style="{StaticResource FieldLabel}" Width="80" />
                                <TextBox Text="{Binding AddAnchorRightMm}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Visibility="{Binding DiagramHighlightBottom, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Total:" Style="{StaticResource FieldLabel}" Width="70" />
                                <TextBox Text="{Binding AddTotalMm, Mode=OneWay}" IsReadOnly="True" Foreground="#9AA5B1" />
                            </StackPanel>
                            <Border BorderBrush="#F4A6A6" BorderThickness="0,1,0,0" Margin="0,8,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Number:" Style="{StaticResource FieldLabel}" Width="70" />
                                <ComboBox ItemsSource="{Binding NumberOptions}" SelectedItem="{Binding AddNumber}" />
                                <TextBlock Text="Position In Section:" Style="{StaticResource FieldLabel}" Width="112" />
                                <TextBox Text="{Binding AddPositionInSection}" />
                            </StackPanel>
                            <!-- Đai C giữ thép gia cường lớp 2 (≥3 cây): đường kính + khoảng cách. -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        Visibility="{Binding ShowAddTieC, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Đai C giữ:" Style="{StaticResource FieldLabel}" Width="70" />
                                <ComboBox ItemsSource="{Binding StirrupDiameterOptions}" ItemStringFormat="'D'0" SelectedItem="{Binding AddTieCDiameterMm}" />
                                <TextBlock Text="@ (mm):" Style="{StaticResource FieldLabel}" Width="64" />
                                <TextBox Text="{Binding AddTieCSpacingMm}" />
                                <TextBlock Text="(0 = không tạo)" Style="{StaticResource FieldLabel}" Foreground="#9AA5B1" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Stirrup (phân bố cốt đai) — bám mẫu: sub-tabs + đánh số mục -->
                        <TabControl Visibility="{Binding IsStirrupTab, Converter={StaticResource BoolToVis}}"
                                    BorderThickness="0" Background="Transparent" Margin="0,-28,0,0">
                            <TabItem Header="Stirrup Distribution">
                                <StackPanel Margin="0,12,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="1. Choose Span - Diameter" FontWeight="SemiBold" Style="{StaticResource FieldLabel}" Width="190" />
                                        <TextBlock Text="Main Diameter:" Style="{StaticResource FieldLabel}" />
                                        <ComboBox ItemsSource="{Binding StirrupDiameterOptions}" ItemStringFormat="'D'0" SelectedItem="{Binding StirrupDiameterMm}" />
                                    </StackPanel>

                                    <RadioButton GroupName="StDist" Margin="0,2" IsChecked="{Binding StirrupUniform}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="2. Stirrup distributed uniform — A1:" Style="{StaticResource FieldLabel}" />
                                            <TextBox Width="70" Text="{Binding StirrupSpacingEndMm}" IsEnabled="{Binding StirrupUniform}" />
                                        </StackPanel>
                                    </RadioButton>

                                    <RadioButton GroupName="StDist" Margin="0,2" IsChecked="{Binding StirrupTwoEnds}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="3. Stirrup distributed 2 ends — A1:" Style="{StaticResource FieldLabel}" />
                                            <TextBox Width="60" Text="{Binding StirrupSpacingEndMm}" IsEnabled="{Binding StirrupTwoEnds}" />
                                            <TextBlock Text="A2:" Style="{StaticResource FieldLabel}" />
                                            <TextBox Width="60" Text="{Binding StirrupSpacingMidMm}" IsEnabled="{Binding StirrupTwoEnds}" />
                                        </StackPanel>
                                    </RadioButton>

                                    <StackPanel Orientation="Horizontal" Margin="20,2,0,0" IsEnabled="{Binding StirrupTwoEnds}">
                                        <TextBlock Text="3.1. Length of End1 + End2" Style="{StaticResource FieldLabel}" Width="170" />
                                        <TextBlock Text="End 1:" Style="{StaticResource FieldLabel}" />
                                        <TextBox Width="70" Text="{Binding StirrupEndZoneStartMm}" />
                                        <TextBlock Text="(mm) End 2:" Style="{StaticResource FieldLabel}" />
                                        <TextBox Width="70" Text="{Binding StirrupEndZoneEndMm}" />
                                        <TextBlock Text="(mm)" Style="{StaticResource FieldLabel}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="4. Distance of first stirrup to the column (mm):" Style="{StaticResource FieldLabel}" Width="270" />
                                        <TextBox Width="70" Text="{Binding StirrupFirstDistanceMm}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                                        <Button Content="All Span" Command="{Binding ApplyStirrupAllSpansCommand}" Padding="14,4" Margin="0,0,8,0" />
                                        <Button Content="Remaining Span" Command="{Binding ApplyStirrupRemainingSpansCommand}" Padding="14,4" Margin="0,0,8,0" />
                                        <Button Content="Delete" Command="{Binding DeleteSelectedStirrupSpanCommand}" Padding="14,4" />
                                    </StackPanel>
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="Additional Stirrup">
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="1. Choose Additional Stirrup Type - Its position:" FontWeight="SemiBold" Margin="0,0,0,6" />
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Icon 1: ĐAI MÓC C — 2 chữ C quay lưng vào nhau (như video) -->
                                        <RadioButton GroupName="AddStType" IsChecked="{Binding AdditionalStirrupCHook}"
                                                     VerticalContentAlignment="Center" Margin="0,0,6,0">
                                            <Border BorderBrush="#222" BorderThickness="1" Background="#E8E8E8" Width="70" Height="48">
                                                <Canvas Width="70" Height="48">
                                                    <!-- khung đai chính (đỏ) -->
                                                    <Rectangle Canvas.Left="10" Canvas.Top="8" Width="50" Height="32" Stroke="#C0392B" StrokeThickness="1.2" />
                                                    <!-- 4 chấm thanh trên + 4 dưới -->
                                                    <Ellipse Canvas.Left="13" Canvas.Top="11" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="26" Canvas.Top="11" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="39" Canvas.Top="11" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="52" Canvas.Top="11" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="13" Canvas.Top="32" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="26" Canvas.Top="32" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="39" Canvas.Top="32" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="52" Canvas.Top="32" Width="5" Height="5" Fill="#C0392B" />
                                                    <!-- 2 móc C (xanh) quay lưng: trái ⊐ phải ⊏ -->
                                                    <Polyline Points="33,12 22,12 22,36 33,36" Stroke="#2949C0" StrokeThickness="1.4" />
                                                    <Polyline Points="37,12 48,12 48,36 37,36" Stroke="#2949C0" StrokeThickness="1.4" />
                                                </Canvas>
                                            </Border>
                                        </RadioButton>
                                        <!-- Icon 2: ĐAI LỒNG KÍN — 1 khung kín ôm thanh giữa (như video) -->
                                        <RadioButton GroupName="AddStType" IsChecked="{Binding AdditionalStirrupClosed}"
                                                     VerticalContentAlignment="Center" Margin="0,0,12,0">
                                            <Border BorderBrush="#222" BorderThickness="1" Background="#E8E8E8" Width="70" Height="48">
                                                <Canvas Width="70" Height="48">
                                                    <Rectangle Canvas.Left="10" Canvas.Top="8" Width="50" Height="32" Stroke="#C0392B" StrokeThickness="1.2" />
                                                    <Ellipse Canvas.Left="13" Canvas.Top="11" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="26" Canvas.Top="11" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="39" Canvas.Top="11" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="52" Canvas.Top="11" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="13" Canvas.Top="32" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="26" Canvas.Top="32" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="39" Canvas.Top="32" Width="5" Height="5" Fill="#C0392B" />
                                                    <Ellipse Canvas.Left="52" Canvas.Top="32" Width="5" Height="5" Fill="#C0392B" />
                                                    <!-- khung kín (xanh) ôm 2 thanh giữa -->
                                                    <Rectangle Canvas.Left="23" Canvas.Top="12" Width="24" Height="24" Stroke="#2949C0" StrokeThickness="1.4" />
                                                </Canvas>
                                            </Border>
                                        </RadioButton>
                                        <TextBlock Text="Diameter:" Style="{StaticResource FieldLabel}" Width="64" />
                                        <ComboBox ItemsSource="{Binding StirrupDiameterOptions}" ItemStringFormat="'D'0" SelectedItem="{Binding AdditionalStirrupDiameterMm}" />
                                        <!-- Lồng kín: Start + End -->
                                        <TextBlock Text="Start:" Style="{StaticResource FieldLabel}" Width="44"
                                                   Visibility="{Binding ShowStartEnd, Converter={StaticResource BoolToVis}}" />
                                        <ComboBox Width="56" ItemsSource="{Binding NumberOptions}" SelectedItem="{Binding AdditionalStirrupStart}"
                                                  Visibility="{Binding ShowStartEnd, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="End:" Style="{StaticResource FieldLabel}" Width="36"
                                                   Visibility="{Binding ShowStartEnd, Converter={StaticResource BoolToVis}}" />
                                        <ComboBox Width="56" ItemsSource="{Binding NumberOptions}" SelectedItem="{Binding AdditionalStirrupEnd}"
                                                  Visibility="{Binding ShowStartEnd, Converter={StaticResource BoolToVis}}" />
                                        <!-- Móc C: vị trí lẻ 1 thanh -->
                                        <TextBlock Text="Vị trí (thanh):" Style="{StaticResource FieldLabel}" Width="84"
                                                   Visibility="{Binding ShowPosition, Converter={StaticResource BoolToVis}}" />
                                        <ComboBox Width="56" ItemsSource="{Binding NumberOptions}" SelectedItem="{Binding AdditionalStirrupStart}"
                                                  Visibility="{Binding ShowPosition, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>

                                    <TextBlock Text="2. Stirrup List - Select to Edit or Delete:" Margin="0,8,0,4" FontWeight="SemiBold" />
                                    <ListBox Height="110" ItemsSource="{Binding AdditionalStirrupList}"
                                             SelectedItem="{Binding SelectedAdditionalStirrup}" />

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                        <Button Content="Modify" Command="{Binding ModifyAdditionalStirrupCommand}" Padding="14,4" Margin="0,0,8,0" />
                                        <Button Content="Add" Command="{Binding AddAdditionalStirrupCommand}" Padding="16,4" Margin="0,0,8,0" />
                                        <Button Content="Remove" Command="{Binding RemoveAdditionalStirrupCommand}" Padding="14,4" />
                                    </StackPanel>
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="Hanger bar For 2nd Beam">
                                <TextBlock Text="Bổ sung ở bước sau." Foreground="#7B8794" Margin="0,12,0,0" />
                            </TabItem>
                            <TabItem Header="Stirrup Shape">
                                <TextBlock Text="Bổ sung ở bước sau." Foreground="#7B8794" Margin="0,12,0,0" />
                            </TabItem>
                        </TabControl>

                        <!-- Anti-bulge rebar (thép chống phình/co ngót) -->
                        <StackPanel Visibility="{Binding IsAntiBulgeTab, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Anti-Shrinkage reinforcement When H > :" Style="{StaticResource FieldLabel}" Width="250" />
                                <TextBox Width="70" Text="{Binding AntiBulgeHeightThresholdMm}" />
                                <TextBlock Text="(mm)" Style="{StaticResource FieldLabel}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Diameter:" Style="{StaticResource FieldLabel}" Width="70" />
                                <ComboBox ItemsSource="{Binding DiameterOptions}" ItemStringFormat="'D'0" SelectedItem="{Binding AntiBulgeDiameterMm}" />
                                <TextBlock Text="Number:" Style="{StaticResource FieldLabel}" Width="64" />
                                <ComboBox ItemsSource="{Binding NumberOptions}" SelectedItem="{Binding AntiBulgeNumber}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Tie D:" Style="{StaticResource FieldLabel}" Width="70" />
                                <ComboBox ItemsSource="{Binding StirrupDiameterOptions}" ItemStringFormat="'D'0" SelectedItem="{Binding AntiBulgeTieDiameterMm}" />
                                <TextBlock Text="@ (mm):" Style="{StaticResource FieldLabel}" Width="64" />
                                <TextBox Text="{Binding AntiBulgeSpacingMm}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Column embed:" Style="{StaticResource FieldLabel}" Width="100" />
                                <TextBox Width="70" Text="{Binding AntiBulgeColumnEmbedMm}" />
                                <TextBlock Text="(mm)" Style="{StaticResource FieldLabel}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Nút chung cho Main + Add -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                    Visibility="{Binding ShowAddButtons, Converter={StaticResource BoolToVis}}">
                            <Button Content="Add" Command="{Binding AddRebarCommand}" Padding="16,4" Margin="0,0,8,0" />
                            <Button Content="Delete Selected" Command="{Binding DeleteSelectedRebarCommand}" Padding="16,4" />
                        </StackPanel>

                        <TextBlock Visibility="{Binding IsPlaceholderTab, Converter={StaticResource BoolToVis}}"
                                   Text="Form chi tiết cho mục này sẽ bổ sung ở bước tiếp theo."
                                   Foreground="#7B8794" TextWrapping="Wrap" />
                    </StackPanel>
                    </ScrollViewer>

                    <!-- Image: mỗi tab Setting dùng một PNG độc lập. Ẩn ở tab Stirrup (ảnh tĩnh không khớp đai phụ). -->
                    <Border Grid.Column="2" BorderBrush="#E3E7EB" BorderThickness="1" CornerRadius="3" Padding="8"
                            Visibility="{Binding ShowDiagramImage, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Image" Foreground="#9AA5B1" HorizontalAlignment="Center" Margin="0,0,0,8" />
                            <Image Source="{Binding SelectedDiagramImagePath}"
                                   Stretch="Uniform"
                                   Width="285"
                                   Height="260"
                                   HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedTabTitle}" HorizontalAlignment="Center" Margin="0,8,0,0"
                                       Foreground="#52606D" FontStyle="Italic" />
                        </StackPanel>
                    </Border>

                    <!-- Section: tab Stirrup — tiết diện + chấm thanh chủ đánh số 1..n để biết vị trí đai phụ. -->
                    <Border Grid.Column="2" BorderBrush="#E3E7EB" BorderThickness="1" CornerRadius="3" Padding="8"
                            Visibility="{Binding ShowSectionPanel, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Section" Foreground="#9AA5B1" HorizontalAlignment="Center" Margin="0,0,0,8" />
                            <Canvas Width="{Binding SectionFrameW}" Height="{Binding SectionFrameH}" HorizontalAlignment="Center"
                                    Background="#F8F8F8">
                                <!-- khung đai chính đỏ -->
                                <Rectangle Canvas.Left="16" Canvas.Top="16" Width="118" Height="218"
                                           Stroke="#C0392B" StrokeThickness="1.5" />
                                <!-- chấm thanh chủ (vẽ TRƯỚC để đai phụ nổi lên trên) -->
                                <ItemsControl ItemsSource="{Binding SectionBars}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Canvas>
                                                <Ellipse Width="{Binding Diameter}" Height="{Binding Diameter}" Fill="#C0392B" />
                                                <TextBlock Text="{Binding Label}" Canvas.Top="14" FontSize="11"
                                                           Foreground="#2949C0" FontWeight="Bold" />
                                            </Canvas>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- đai phụ (xanh) vẽ SAU CÙNG → nổi lên trên chấm, móc thấy rõ -->
                                <ItemsControl ItemsSource="{Binding SectionStirrups}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Canvas>
                                                <Rectangle Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}"
                                                           Width="{Binding Width}" Height="{Binding Height}"
                                                           Stroke="#2949C0" StrokeThickness="1.4"
                                                           Visibility="{Binding IsClosed, Converter={StaticResource BoolToVis}}" />
                                                <Path Data="{Binding PathData}" Stroke="#2949C0" StrokeThickness="1.8" />
                                                <Ellipse Canvas.Left="{Binding HookTopX}" Canvas.Top="{Binding HookTopY}"
                                                         Width="{Binding HookSize}" Height="{Binding HookSize}"
                                                         Stroke="#2949C0" StrokeThickness="1.8" />
                                                <Ellipse Canvas.Left="{Binding HookBotX}" Canvas.Top="{Binding HookBotY}"
                                                         Width="{Binding HookSize}" Height="{Binding HookSize}"
                                                         Stroke="#2949C0" StrokeThickness="1.8" />
                                            </Canvas>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Canvas>
                            <TextBlock Text="Số 1..n = thứ tự thép chủ (trái→phải)" HorizontalAlignment="Center"
                                       Margin="0,8,0,0" Foreground="#52606D" FontStyle="Italic" FontSize="11" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Dưới: mặt đứng dầm (preview) — vẽ thanh thép đỏ theo thông số, giống form mẫu. Dầm đã chọn
                 từ Ribbon (pick-first) nên không cần nút Pick Beam. -->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0"
                    BorderBrush="#D9DEE3" BorderThickness="1" CornerRadius="3" Background="White" Padding="10">
                <Canvas Background="White" ClipToBounds="True">
                    <ItemsControl ItemsSource="{Binding PreviewRects}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Rectangle Width="{Binding Width}" Height="{Binding Height}"
                                           Fill="{Binding Fill}" Stroke="{Binding Stroke}"
                                           StrokeThickness="{Binding Thickness}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding PreviewLines}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                      X2="{Binding X2}" Y2="{Binding Y2}"
                                      Stroke="{Binding Stroke}"
                                      StrokeThickness="{Binding Thickness}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding PreviewTexts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}"
                                           Foreground="{Binding Foreground}"
                                           FontSize="{Binding FontSize}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>
            </Border>
        </Grid>
    </DockPanel>
</Window>
