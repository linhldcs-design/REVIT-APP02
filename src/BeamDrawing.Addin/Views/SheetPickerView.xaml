<Window x:Class="BeamDrawing.Addin.Views.SheetPickerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chọn Sheet" Height="420" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        FontFamily="{DynamicResource Font.Family}" FontSize="12">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BeamDrawing.Addin;component/Resources/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <DockPanel Margin="10">
        <TextBlock DockPanel.Dock="Top" Text="Chọn sheet có sẵn trong project:"
                   Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"/>
        <TextBox DockPanel.Dock="Top" x:Name="FilterBox" Style="{DynamicResource TextBox.Standard}"
                 Margin="0,0,0,6" TextChanged="FilterBox_TextChanged"/>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK" Width="80" Margin="0,0,8,0" Style="{DynamicResource Button.Primary}" Click="Ok_Click"/>
            <Button Content="Cancel" Width="80" Style="{DynamicResource Button.Primary}" Click="Cancel_Click"/>
        </StackPanel>
        <ListBox x:Name="SheetList" DisplayMemberPath="Display"
                 Background="{DynamicResource Brush.Background}" Foreground="{DynamicResource Brush.Text}"
                 BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                 MouseDoubleClick="SheetList_MouseDoubleClick"/>
    </DockPanel>
</Window>
