<Window x:Class="BeamDrawing.Addin.Views.BeamDrawingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BeamDrawing.Addin.Views"
        Title="Beam Drawing" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Background}"
        FontFamily="{DynamicResource Font.Family}" FontSize="12">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BeamDrawing.Addin;component/Resources/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Header ô bảng (nền xám, viền) -->
            <Style x:Key="CellHeader" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource Brush.Header}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>
            <Style x:Key="CellHeaderText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Margin" Value="4,3"/>
            </Style>
            <!-- Nhãn tag tròn đỏ (T1, D0...) -->
            <Style x:Key="TagBadge" TargetType="Border">
                <Setter Property="Width" Value="22"/>
                <Setter Property="Height" Value="22"/>
                <Setter Property="CornerRadius" Value="11"/>
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Background" Value="{DynamicResource Brush.Background}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="TagBadgeText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="RowCombo" TargetType="ComboBox" BasedOn="{StaticResource ComboBox.Standard}">
                <Setter Property="Height" Value="24"/>
                <Setter Property="Margin" Value="2"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="470"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== CỘT 1: Template Setting ===== -->
        <DockPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
            <TextBlock DockPanel.Dock="Top" Text="Template Setting:" FontWeight="Bold" FontSize="14"
                       Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"/>
            <TextBlock DockPanel.Dock="Top" Text="Setting Name:" Style="{DynamicResource TextBlock.Label}"/>
            <TextBox DockPanel.Dock="Top" Text="{Binding SettingName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{DynamicResource TextBox.Standard}" Margin="0,0,0,6"/>
            <UniformGrid DockPanel.Dock="Top" Columns="3" Margin="0,0,0,4">
                <Button Content="Add" Command="{Binding AddSettingCommand}" Style="{DynamicResource Button.Primary}" Margin="1"/>
                <Button Content="Update" Command="{Binding UpdateSettingCommand}" Style="{DynamicResource Button.Primary}" Margin="1"/>
                <Button Content="Delete" Command="{Binding DeleteSettingCommand}" Style="{DynamicResource Button.Primary}" Margin="1"/>
            </UniformGrid>
            <UniformGrid DockPanel.Dock="Top" Columns="3" Margin="0,0,0,8">
                <Button Content="Load" Command="{Binding LoadSettingCommand}" Style="{DynamicResource Button.Primary}" Margin="1"/>
                <Button Content="Export" Command="{Binding ExportSettingCommand}" Style="{DynamicResource Button.Primary}" Margin="1"/>
                <Button Content="Import" Command="{Binding ImportSettingCommand}" Style="{DynamicResource Button.Primary}" Margin="1"/>
            </UniformGrid>
            <TextBlock DockPanel.Dock="Top" Text="Setting List" Style="{DynamicResource TextBlock.Label}"/>
            <UniformGrid DockPanel.Dock="Bottom" Columns="2" Margin="0,6,0,0">
                <Button Content="Up" Command="{Binding MoveUpCommand}" Style="{DynamicResource Button.Primary}" Margin="1"/>
                <Button Content="Down" Command="{Binding MoveDownCommand}" Style="{DynamicResource Button.Primary}" Margin="1"/>
            </UniformGrid>
            <ListBox ItemsSource="{Binding Settings}" SelectedItem="{Binding SelectedSetting}"
                     DisplayMemberPath="Name"
                     Background="{DynamicResource Brush.Background}" Foreground="{DynamicResource Brush.Text}"
                     BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"/>
        </DockPanel>

        <!-- ===== CỘT 2: Diagram ===== -->
        <DockPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,0">
            <TextBlock DockPanel.Dock="Top" Text="Setting" FontWeight="Bold" FontSize="14"
                       Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,4"/>
            <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1"
                    Background="{DynamicResource Brush.Background}">
                <views:BeamDiagramView/>
            </Border>
        </DockPanel>

        <!-- ===== CỘT 3: Bảng cấu hình ===== -->
        <ScrollViewer Grid.Row="0" Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- REBAR TAG SECTIONAL ELEVATION -->
                <Border Style="{StaticResource CellHeader}">
                    <DockPanel>
                        <CheckBox DockPanel.Dock="Right" IsChecked="{Binding RebarTagSectionalEnabled}" Margin="4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="REBAR TAG SECTIONAL ELEVATION" Style="{StaticResource CellHeaderText}"/>
                    </DockPanel>
                </Border>
                <Grid Margin="0,2,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource TagBadge}"><TextBlock Text="T1" Style="{StaticResource TagBadgeText}"/></Border>
                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Resources.RebarTagTypes}" SelectedItem="{Binding T1Tag}" Style="{StaticResource RowCombo}"/>
                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource TagBadge}"><TextBlock Text="4" Style="{StaticResource TagBadgeText}"/></Border>
                    <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding Resources.RebarTagTypes}" SelectedItem="{Binding Item4Tag}" Style="{StaticResource RowCombo}"/>
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource TagBadge}"><TextBlock Text="T2" Style="{StaticResource TagBadgeText}"/></Border>
                    <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Resources.RebarTagTypes}" SelectedItem="{Binding T2Tag}" Style="{StaticResource RowCombo}"/>
                    <CheckBox Grid.Row="1" Grid.Column="3" Content="Rebar Break Symbol" IsChecked="{Binding RebarBreakSymbol}" Style="{DynamicResource CheckBox.Standard}" VerticalAlignment="Center" Margin="2"/>
                </Grid>

                <!-- REBAR TAG CROSS SECTION -->
                <Border Style="{StaticResource CellHeader}">
                    <DockPanel>
                        <CheckBox DockPanel.Dock="Right" IsChecked="{Binding RebarTagCrossEnabled}" Margin="4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="REBAR TAG CROSS SECTION" Style="{StaticResource CellHeaderText}"/>
                    </DockPanel>
                </Border>
                <Grid Margin="0,2,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource TagBadge}"><TextBlock Text="D0" Style="{StaticResource TagBadgeText}"/></Border>
                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Resources.RebarTagTypes}" SelectedItem="{Binding D0Tag}" Style="{StaticResource RowCombo}"/>
                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource TagBadge}"><TextBlock Text="D3" Style="{StaticResource TagBadgeText}"/></Border>
                    <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding Resources.RebarTagTypes}" SelectedItem="{Binding D3Tag}" Style="{StaticResource RowCombo}"/>
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource TagBadge}"><TextBlock Text="D1" Style="{StaticResource TagBadgeText}"/></Border>
                    <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Resources.RebarTagTypes}" SelectedItem="{Binding D1Tag}" Style="{StaticResource RowCombo}"/>
                    <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource TagBadge}"><TextBlock Text="D4" Style="{StaticResource TagBadgeText}"/></Border>
                    <ComboBox Grid.Row="1" Grid.Column="3" ItemsSource="{Binding Resources.RebarTagTypes}" SelectedItem="{Binding D4Tag}" Style="{StaticResource RowCombo}"/>
                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource TagBadge}"><TextBlock Text="D2" Style="{StaticResource TagBadgeText}"/></Border>
                    <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Resources.RebarTagTypes}" SelectedItem="{Binding D2Tag}" Style="{StaticResource RowCombo}"/>
                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource TagBadge}"><TextBlock Text="D5" Style="{StaticResource TagBadgeText}"/></Border>
                    <ComboBox Grid.Row="2" Grid.Column="3" ItemsSource="{Binding Resources.RebarTagTypes}" SelectedItem="{Binding D5Tag}" Style="{StaticResource RowCombo}"/>
                </Grid>

                <!-- SPOT ELEVATION | DIMENSION -->
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CellHeader}">
                        <DockPanel><CheckBox DockPanel.Dock="Right" IsChecked="{Binding SpotElevationEnabled}" Margin="4,0" VerticalAlignment="Center"/><TextBlock Text="SPOT ELEVATION" Style="{StaticResource CellHeaderText}"/></DockPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CellHeader}">
                        <DockPanel><CheckBox DockPanel.Dock="Right" IsChecked="{Binding DimensionEnabled}" Margin="4,0" VerticalAlignment="Center"/><TextBlock Text="DIMENSION" Style="{StaticResource CellHeaderText}"/></DockPanel>
                    </Border>
                </Grid>
                <Grid Margin="0,2,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                    <ComboBox Grid.Row="0" Grid.Column="0" ItemsSource="{Binding Resources.SpotElevationTypes}" SelectedItem="{Binding SpotElevationType}" Style="{StaticResource RowCombo}"/>
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource TagBadge}"><TextBlock Text="SE" Style="{StaticResource TagBadgeText}"/></Border>
                    <ComboBox Grid.Row="0" Grid.Column="2" ItemsSource="{Binding Resources.DimensionTypes}" SelectedItem="{Binding SectionalDimType}" Style="{StaticResource RowCombo}"/>
                    <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding SpotElevationValue}" Style="{DynamicResource TextBox.Standard}" Height="24" Margin="2"/>
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource TagBadge}"><TextBlock Text="CS" Style="{StaticResource TagBadgeText}"/></Border>
                    <ComboBox Grid.Row="1" Grid.Column="2" ItemsSource="{Binding Resources.DimensionTypes}" SelectedItem="{Binding CrossDimType}" Style="{StaticResource RowCombo}"/>
                </Grid>

                <!-- VIEW TEMPLATE / VIEWPORT / SECTION TYPE / SCALE (Sectional | Cross) -->
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CellHeader}"><TextBlock Text="VIEW TEMPLATE SECTIONAL ELE." Style="{StaticResource CellHeaderText}"/></Border>
                    <Border Grid.Column="1" Style="{StaticResource CellHeader}"><TextBlock Text="VIEW TEMPLATE CROSS SECTION" Style="{StaticResource CellHeaderText}"/></Border>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Resources.ViewTemplates}" SelectedItem="{Binding SectionalViewTemplate}" Style="{StaticResource RowCombo}"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Resources.ViewTemplates}" SelectedItem="{Binding CrossViewTemplate}" Style="{StaticResource RowCombo}"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CellHeader}"><TextBlock Text="VIEWPORT SECTIONAL ELE." Style="{StaticResource CellHeaderText}"/></Border>
                    <Border Grid.Column="1" Style="{StaticResource CellHeader}"><TextBlock Text="VIEWPORT CROSS SECTION" Style="{StaticResource CellHeaderText}"/></Border>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Resources.ViewportTypes}" SelectedItem="{Binding SectionalViewport}" Style="{StaticResource RowCombo}"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Resources.ViewportTypes}" SelectedItem="{Binding CrossViewport}" Style="{StaticResource RowCombo}"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CellHeader}"><TextBlock Text="SECTION TYPE SECTIONAL ELE." Style="{StaticResource CellHeaderText}"/></Border>
                    <Border Grid.Column="1" Style="{StaticResource CellHeader}"><TextBlock Text="SECTION TYPE CROSS SECTION" Style="{StaticResource CellHeaderText}"/></Border>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Resources.SectionTypes}" SelectedItem="{Binding SectionalSectionType}" Style="{StaticResource RowCombo}"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Resources.SectionTypes}" SelectedItem="{Binding CrossSectionType}" Style="{StaticResource RowCombo}"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CellHeader}"><TextBlock Text="SCALE SECTIONAL ELE." Style="{StaticResource CellHeaderText}"/></Border>
                    <Border Grid.Column="1" Style="{StaticResource CellHeader}"><TextBlock Text="SCALE TYPE CROSS SECTION" Style="{StaticResource CellHeaderText}"/></Border>
                </Grid>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding SectionalScale}" Style="{DynamicResource TextBox.Standard}" Height="24" Margin="2"/>
                    <TextBox Grid.Column="1" Text="{Binding CrossScale}" Style="{DynamicResource TextBox.Standard}" Height="24" Margin="2"/>
                </Grid>

                <!-- BREAK LINE | TITLE BLOCK -->
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CellHeader}">
                        <DockPanel><CheckBox DockPanel.Dock="Right" IsChecked="{Binding BreakLineEnabled}" Margin="4,0" VerticalAlignment="Center"/><TextBlock Text="BREAK LINE - NÉT CẮT" Style="{StaticResource CellHeaderText}"/></DockPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CellHeader}"><TextBlock Text="TITLE BLOCK" Style="{StaticResource CellHeaderText}"/></Border>
                </Grid>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource TagBadge}"><TextBlock Text="A" Style="{StaticResource TagBadgeText}"/></Border>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Resources.BreakLineFamilies}" SelectedItem="{Binding BreakLineFamily}" Style="{StaticResource RowCombo}"/>
                    <ComboBox Grid.Column="2" ItemsSource="{Binding Resources.TitleBlocks}" SelectedItem="{Binding TitleBlock}" Style="{StaticResource RowCombo}"/>
                </Grid>

                <!-- SHEET NUMBER | SHEET NAME -->
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CellHeader}"><TextBlock Text="SHEET NUMBER" Style="{StaticResource CellHeaderText}"/></Border>
                    <Border Grid.Column="1" Style="{StaticResource CellHeader}"><TextBlock Text="SHEET NAME" Style="{StaticResource CellHeaderText}"/></Border>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding SheetNumber}" Style="{DynamicResource TextBox.Standard}" Height="24" Margin="2"/>
                    <Button Grid.Column="1" Command="{Binding PickSheetCommand}" Style="{DynamicResource Button.Primary}" Height="24" Width="24" Margin="0,2" Padding="0" ToolTip="Chọn sheet có sẵn">
                        <Canvas Width="14" Height="14">
                            <Ellipse Canvas.Left="1" Canvas.Top="1" Width="9" Height="9"
                                     Stroke="{DynamicResource Brush.Text}" StrokeThickness="1.6"/>
                            <Line X1="9" Y1="9" X2="13" Y2="13"
                                  Stroke="{DynamicResource Brush.Text}" StrokeThickness="1.8"/>
                        </Canvas>
                    </Button>
                    <TextBox Grid.Column="2" Text="{Binding SheetName}" Style="{DynamicResource TextBox.Standard}" Height="24" Margin="2"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- ===== Thanh dưới ===== -->
        <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                <CheckBox Content="Long Section" IsChecked="{Binding LongSection}" Style="{DynamicResource CheckBox.Standard}" Margin="0,0,8,0"/>
                <TextBlock Text="View Name :" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text}" Margin="0,0,4,0"/>
                <TextBox Text="{Binding BeamDetailViewName}" Style="{DynamicResource TextBox.Standard}" Width="120" Height="24" Margin="0,0,12,0"/>
                <CheckBox Content="Cross Section" IsChecked="{Binding CrossSection}" Style="{DynamicResource CheckBox.Standard}" Margin="0,0,8,0"/>
                <TextBlock Text="View Name :" VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text}" Margin="0,0,4,0"/>
                <TextBox Text="{Binding CrossViewName}" Style="{DynamicResource TextBox.Standard}" Width="120" Height="24" Margin="0,0,12,0"/>
                <CheckBox Content="Cross Section for Multi Beam" IsChecked="{Binding CrossSectionForMultiBeam}" Style="{DynamicResource CheckBox.Standard}" Margin="0,0,12,0"/>
                <CheckBox Content="Pick the pillow you want to dim" IsChecked="{Binding PickPillowToDim}" Style="{DynamicResource CheckBox.Standard}" Margin="0,0,12,0"/>
                <CheckBox Content="Create view 3D" IsChecked="{Binding CreateView3D}" Style="{DynamicResource CheckBox.Standard}" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding ValidationMessage}" Foreground="{DynamicResource Brush.Danger}" TextWrapping="Wrap" VerticalAlignment="Center"/>
            </WrapPanel>
            <Button Grid.Column="1" Content="Ok" Command="{Binding OkCommand}" Style="{DynamicResource Button.Primary}" MinWidth="110" Height="32"/>
        </Grid>
    </Grid>
</Window>
