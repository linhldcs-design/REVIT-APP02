<Window x:Class="IsolatedFootingRebar.Views.FootingRebarView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:IsolatedFootingRebar.Views"
        Title="Isolated Footing v1.1" Height="742" Width="846"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        FontFamily="Segoe UI" FontSize="12">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/IsolatedFootingRebar;component/Resources/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:InverseBoolConverter x:Key="InverseBool"/>

            <Style x:Key="FootingTabItem" TargetType="TabItem">
                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="SelectTabOnHeaderClick"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0,0,1,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Grid>
                                <Border x:Name="HeaderBorder" BorderBrush="#FF202020" BorderThickness="1,1,1,0"
                                        Background="#FFF2F2F2" Padding="12,7" MinHeight="35">
                                    <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="HeaderBorder" Property="Background" Value="#FFE00000"/>
                                    <Setter TargetName="HeaderBorder" Property="Panel.ZIndex" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SectionBox" TargetType="Border">
                <Setter Property="BorderBrush" Value="#FFB8B8B8"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Background" Value="#FFF7F7F7"/>
            </Style>

            <Style x:Key="PlainButton" TargetType="Button">
                <Setter Property="MinWidth" Value="100"/>
                <Setter Property="Height" Value="30"/>
                <Setter Property="Padding" Value="18,4"/>
                <Setter Property="Background" Value="#FFE9E9E9"/>
                <Setter Property="BorderBrush" Value="#FFB8B8B8"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" BorderBrush="#FFB8B8B8" BorderThickness="1" Margin="8,8,8,12" Background="#FFFFFFFF">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#FFF0F0F0" BorderBrush="#FFB8B8B8" BorderThickness="0,0,0,1" Padding="6">
                    <TextBlock Text="Configuration" FontWeight="SemiBold"/>
                </Border>
                <StackPanel Orientation="Horizontal" Margin="14,14,0,14" VerticalAlignment="Center">
                    <TextBlock Text="Current Configuration:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <ComboBox Width="220" Height="30" ItemsSource="{Binding PresetNames}"
                              SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                              IsEditable="True"
                              Text="{Binding PresetNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="Chọn cấu hình đã lưu để nạp, hoặc gõ tên mới rồi bấm Lưu."/>
                    <Button Width="34" Height="30" Margin="18,0,4,0" BorderThickness="1" Background="#FFE9E9E9" BorderBrush="#FFB8B8B8"
                            Content="💾" Command="{Binding SavePresetCommand}" ToolTip="Lưu cấu hình hiện tại"/>
                    <Button Width="34" Height="30" BorderThickness="1" Background="#FFE9E9E9" BorderBrush="#FFB8B8B8"
                            Content="✕" Command="{Binding DeletePresetCommand}" ToolTip="Xoá cấu hình đang chọn"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" BorderBrush="#FFB8B8B8" BorderThickness="0,1,0,0" Background="#FFEDEDED" Padding="0,8">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" Margin="12,0,12,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.Foreground.Secondary}" TextWrapping="Wrap"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Create" Style="{DynamicResource PlainButton}" Command="{Binding CreateCommand}" Margin="0,0,8,0"/>
                    <Button Content="Close" Style="{DynamicResource PlainButton}" Command="{Binding CloseCommand}" Margin="0,0,8,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Margin="0" BorderThickness="0" Background="#FFFFFFFF" ItemContainerStyle="{DynamicResource FootingTabItem}">
            <TabItem>
                <TabItem.Header><TextBlock Text="Common Settings"/></TabItem.Header>
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="392"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="14,10,10,0">
                        <TextBlock Text="Pick line to specify the direction of main Rebar:" Margin="0,0,0,48"/>
                        <Image Source="/IsolatedFootingRebar;component/Resources/Images/CommonSettingsReal.png"
                               Width="390"
                               Height="430"
                               HorizontalAlignment="Left"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True"/>
                    </StackPanel>
                    <Border Grid.Column="1" Style="{DynamicResource SectionBox}" Margin="0,0,20,0" Height="200" VerticalAlignment="Top">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#FFF0F0F0" BorderBrush="#FFB8B8B8" BorderThickness="0,0,0,1" Padding="8">
                                <TextBlock Text="Cover Settings" FontWeight="SemiBold"/>
                            </Border>
                            <Grid Margin="14,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="100"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="50"/><RowDefinition Height="50"/><RowDefinition Height="50"/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Bottom Concrete Cover:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Style="{DynamicResource NumberTextBox}" Text="{Binding BottomCoverMm}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="(mm)" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <TextBlock Grid.Row="1" Text="Top Concrete Cover:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{DynamicResource NumberTextBox}" Text="{Binding TopCoverMm}"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="(mm)" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <TextBlock Grid.Row="2" Text="Side Concrete Cover:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Style="{DynamicResource NumberTextBox}" Text="{Binding SideCoverMm}"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="(mm)" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header><CheckBox Content="Bottom Layer" IsChecked="{Binding BottomEnabled}" FontWeight="SemiBold"/></TabItem.Header>
                <Grid Margin="8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="405"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Style="{DynamicResource SectionBox}">
                        <Image Source="/IsolatedFootingRebar;component/Resources/Images/BottomLayerReal.png"
                               Stretch="Uniform" SnapsToDevicePixels="True"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0"><Border Style="{DynamicResource SectionBox}" Margin="0,0,0,12"><DockPanel><Border DockPanel.Dock="Top" Background="#FFF0F0F0" BorderBrush="#FFB8B8B8" BorderThickness="0,0,0,1" Padding="8"><TextBlock Text="X Direction"/></Border><ContentControl Content="{Binding BottomX}" ContentTemplate="{DynamicResource DirectionTemplate}"/></DockPanel></Border><Border Style="{DynamicResource SectionBox}"><DockPanel><Border DockPanel.Dock="Top" Background="#FFF0F0F0" BorderBrush="#FFB8B8B8" BorderThickness="0,0,0,1" Padding="8"><TextBlock Text="Y Direction"/></Border><ContentControl Content="{Binding BottomY}" ContentTemplate="{DynamicResource DirectionTemplate}"/></DockPanel></Border></StackPanel>
                </Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header><CheckBox Content="Top Layer" IsChecked="{Binding TopEnabled}" FontWeight="SemiBold"/></TabItem.Header>
                <Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="405"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Style="{DynamicResource SectionBox}"><Image Source="/IsolatedFootingRebar;component/Resources/Images/TopLayerReal.png" Stretch="Uniform" SnapsToDevicePixels="True"/></Border><StackPanel Grid.Column="1" Margin="12,0,0,0"><Border Style="{DynamicResource SectionBox}" Margin="0,0,0,12"><DockPanel><Border DockPanel.Dock="Top" Background="#FFF0F0F0" BorderBrush="#FFB8B8B8" BorderThickness="0,0,0,1" Padding="8"><TextBlock Text="X Direction"/></Border><ContentControl Content="{Binding TopX}" ContentTemplate="{DynamicResource DirectionTemplate}"/></DockPanel></Border><Border Style="{DynamicResource SectionBox}"><DockPanel><Border DockPanel.Dock="Top" Background="#FFF0F0F0" BorderBrush="#FFB8B8B8" BorderThickness="0,0,0,1" Padding="8"><TextBlock Text="Y Direction"/></Border><ContentControl Content="{Binding TopY}" ContentTemplate="{DynamicResource DirectionTemplate}"/></DockPanel></Border></StackPanel></Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header><CheckBox Content="Mid Layer" IsChecked="{Binding MidEnabled}"/></TabItem.Header>
                <Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="405"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Style="{DynamicResource SectionBox}"><Grid><Image Source="/IsolatedFootingRebar;component/Resources/Images/MidLayerReal.png" Stretch="Uniform" SnapsToDevicePixels="True"/><TextBox Width="66" Height="30" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,112" Style="{DynamicResource NumberTextBox}" Text="{Binding MidLayers}"/></Grid></Border><StackPanel Grid.Column="1" Margin="12,0,0,0" IsEnabled="{Binding MidEnabled}"><Border Style="{DynamicResource SectionBox}" Margin="0,0,0,12"><DockPanel><Border DockPanel.Dock="Top" Background="#FFF0F0F0" BorderBrush="#FFB8B8B8" BorderThickness="0,0,0,1" Padding="8"><TextBlock Text="X Direction"/></Border><ContentControl Content="{Binding MidX}" ContentTemplate="{DynamicResource DirectionTemplate}"/></DockPanel></Border><Border Style="{DynamicResource SectionBox}"><DockPanel><Border DockPanel.Dock="Top" Background="#FFF0F0F0" BorderBrush="#FFB8B8B8" BorderThickness="0,0,0,1" Padding="8"><TextBlock Text="Y Direction"/></Border><ContentControl Content="{Binding MidY}" ContentTemplate="{DynamicResource DirectionTemplate}"/></DockPanel></Border></StackPanel></Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header><CheckBox Content="Vertical Reinforced" IsChecked="{Binding VerticalEnabled}"/></TabItem.Header>
                <Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="405"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Style="{DynamicResource SectionBox}"><Image Source="/IsolatedFootingRebar;component/Resources/Images/VerticalLayerReal.png" Stretch="Uniform" SnapsToDevicePixels="True"/></Border><Border Grid.Column="1" Margin="12,0,0,0" Style="{DynamicResource SectionBox}" IsEnabled="{Binding VerticalEnabled}"><DockPanel><Border DockPanel.Dock="Top" Background="#FFF0F0F0" BorderBrush="#FFB8B8B8" BorderThickness="0,0,0,1" Padding="8"><TextBlock Text="Bar Chair (thép kê đỡ lưới trên)"/></Border><Grid Margin="14"><Grid.RowDefinitions><RowDefinition Height="44"/><RowDefinition Height="44"/><RowDefinition Height="44"/><RowDefinition Height="44"/><RowDefinition Height="44"/><RowDefinition Height="44"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="150"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Diameter:" FontWeight="SemiBold" VerticalAlignment="Center"/><ComboBox Grid.Column="1" ItemsSource="{Binding DiameterOptions}" SelectedItem="{Binding VerticalDiameterMm}" Height="30"/><TextBlock Grid.Row="1" Text="Rebar Spacing X:" FontWeight="SemiBold" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Style="{DynamicResource NumberTextBox}" Text="{Binding VerticalSpacingXMm}"/><TextBlock Grid.Row="1" Grid.Column="2" Text="(mm)" VerticalAlignment="Center" Margin="8,0,0,0"/><TextBlock Grid.Row="2" Text="Rebar Spacing Y:" FontWeight="SemiBold" VerticalAlignment="Center"/><TextBox Grid.Row="2" Grid.Column="1" Style="{DynamicResource NumberTextBox}" Text="{Binding VerticalSpacingYMm}"/><TextBlock Grid.Row="2" Grid.Column="2" Text="(mm)" VerticalAlignment="Center" Margin="8,0,0,0"/><TextBlock Grid.Row="3" Text="Chair Width (bề ngang đỉnh):" FontWeight="SemiBold" VerticalAlignment="Center"/><TextBox Grid.Row="3" Grid.Column="1" Style="{DynamicResource NumberTextBox}" Text="{Binding VerticalWidthMm}"/><TextBlock Grid.Row="3" Grid.Column="2" Text="(mm)" VerticalAlignment="Center" Margin="8,0,0,0"/><TextBlock Grid.Row="4" Text="Leg Length (chân ngang):" FontWeight="SemiBold" VerticalAlignment="Center"/><TextBox Grid.Row="4" Grid.Column="1" Style="{DynamicResource NumberTextBox}" Text="{Binding VerticalHookLengthMm}"/><TextBlock Grid.Row="4" Grid.Column="2" Text="(mm)" VerticalAlignment="Center" Margin="8,0,0,0"/></Grid></DockPanel></Border></Grid>
            </TabItem>

            <TabItem>
                <TabItem.Header><CheckBox Content="Horizontal Reinforced" IsChecked="{Binding HorizontalEnabled}" FontWeight="SemiBold"/></TabItem.Header>
                <Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="405"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Style="{DynamicResource SectionBox}"><Grid><Image Source="/IsolatedFootingRebar;component/Resources/Images/HorizontalLayerReal.png" Stretch="Uniform" SnapsToDevicePixels="True"/><TextBox Width="66" Height="30" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,112" Style="{DynamicResource NumberTextBox}" Text="{Binding HorizontalLayers}"/></Grid></Border><StackPanel Grid.Column="1" Margin="12,0,0,0"><Border Style="{DynamicResource SectionBox}" Margin="0,0,0,12"><DockPanel><Border DockPanel.Dock="Top" Background="#FFF0F0F0" BorderBrush="#FFB8B8B8" BorderThickness="0,0,0,1" Padding="8"><TextBlock Text="X Direction"/></Border><Grid Margin="14"><Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="48"/><RowDefinition Height="60"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="150"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Diameter:" FontWeight="SemiBold" VerticalAlignment="Center"/><ComboBox Grid.Column="1" ItemsSource="{Binding DiameterOptions}" SelectedItem="{Binding HorizontalDiameterMm}" Height="30"/><CheckBox Grid.Row="1" Content="Rebar Hook Length" IsChecked="{Binding HorizontalHookEnabled}" FontWeight="SemiBold" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Style="{DynamicResource NumberTextBox}" IsEnabled="{Binding HorizontalHookEnabled}" Text="{Binding HorizontalHookLengthMm}"/><TextBlock Grid.Row="1" Grid.Column="2" Text="(mm)" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/><StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center"><RadioButton Content="Segmented Stirrup" IsChecked="{Binding HorizontalClosed, Converter={StaticResource InverseBool}}" Margin="0,0,16,0"/><RadioButton Content="Closed Stirrup" IsChecked="{Binding HorizontalClosed}"/></StackPanel></Grid></DockPanel></Border><Border Style="{DynamicResource SectionBox}"><DockPanel><Border DockPanel.Dock="Top" Background="#FFF0F0F0" BorderBrush="#FFB8B8B8" BorderThickness="0,0,0,1" Padding="8"><TextBlock Text="Y Direction"/></Border><Grid Margin="14"><Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="48"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="170"/><ColumnDefinition Width="150"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Diameter:" FontWeight="SemiBold" VerticalAlignment="Center"/><ComboBox Grid.Column="1" ItemsSource="{Binding DiameterOptions}" SelectedItem="{Binding HorizontalDiameterMm}" Height="30"/><CheckBox Grid.Row="1" Content="Rebar Hook Length" IsChecked="{Binding HorizontalHookEnabled}" FontWeight="SemiBold" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" Style="{DynamicResource NumberTextBox}" IsEnabled="{Binding HorizontalHookEnabled}" Text="{Binding HorizontalHookLengthMm}"/><TextBlock Grid.Row="1" Grid.Column="2" Text="(mm)" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/></Grid></DockPanel></Border></StackPanel></Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>




