<Window x:Class="BeamRebar.Addin.Views.QuickSettingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Setting - Beam Rebar (TCVN)" Height="640" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Background}"
        FontFamily="{DynamicResource Font.Family}" FontSize="12">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BeamRebar.Addin;component/Resources/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,10,0,4"/>
            </Style>
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,6,0"/>
            </Style>
            <Style x:Key="Combo" TargetType="ComboBox">
                <Setter Property="Width" Value="64"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="Margin" Value="2"/>
            </Style>
            <Style x:Key="Field" TargetType="TextBox">
                <Setter Property="Width" Value="56"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style x:Key="Check" TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,6,0"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== Cột trái: thép chủ + gia cường ===== -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="THÉP CHỦ (Main Bars)" Style="{StaticResource SectionHeader}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="2. Thép chủ trên:" Width="150" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Counts}" SelectedItem="{Binding MainTopCount}"/>
                        <TextBlock Text="x" Style="{StaticResource FieldLabel}" Margin="4,0"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Diameters}" SelectedItem="{Binding MainTopDiameter}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="6. Thép chủ dưới:" Width="150" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Counts}" SelectedItem="{Binding MainBottomCount}"/>
                        <TextBlock Text="x" Style="{StaticResource FieldLabel}" Margin="4,0"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Diameters}" SelectedItem="{Binding MainBottomDiameter}"/>
                    </StackPanel>

                    <TextBlock Text="THÉP GIA CƯỜNG (Additional)" Style="{StaticResource SectionHeader}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <CheckBox Style="{StaticResource Check}" IsChecked="{Binding TopAddEnabled}"/>
                        <TextBlock Text="1. Gia cường trên L1:" Width="150" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Counts}" SelectedItem="{Binding TopAddCount}"/>
                        <TextBlock Text="x" Style="{StaticResource FieldLabel}" Margin="4,0"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Diameters}" SelectedItem="{Binding TopAddDiameter}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <CheckBox Style="{StaticResource Check}" IsChecked="{Binding TopAdd2Enabled}"/>
                        <TextBlock Text="3. Gia cường trên L2:" Width="150" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Counts}" SelectedItem="{Binding TopAdd2Count}"/>
                        <TextBlock Text="x" Style="{StaticResource FieldLabel}" Margin="4,0"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Diameters}" SelectedItem="{Binding TopAdd2Diameter}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <CheckBox Style="{StaticResource Check}" IsChecked="{Binding BotAddEnabled}"/>
                        <TextBlock Text="7. Gia cường dưới L1:" Width="150" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Counts}" SelectedItem="{Binding BotAddCount}"/>
                        <TextBlock Text="x" Style="{StaticResource FieldLabel}" Margin="4,0"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Diameters}" SelectedItem="{Binding BotAddDiameter}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <CheckBox Style="{StaticResource Check}" IsChecked="{Binding BotAdd2Enabled}"/>
                        <TextBlock Text="4. Gia cường dưới L2:" Width="150" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Counts}" SelectedItem="{Binding BotAdd2Count}"/>
                        <TextBlock Text="x" Style="{StaticResource FieldLabel}" Margin="4,0"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Diameters}" SelectedItem="{Binding BotAdd2Diameter}"/>
                    </StackPanel>
                </StackPanel>

                <!-- ===== Cột phải: đai + chống phình + cover ===== -->
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="5. CỐT ĐAI (Stirrup)" Style="{StaticResource SectionHeader}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Đường kính:" Width="90" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Diameters}" SelectedItem="{Binding StirrupDiameter}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <RadioButton GroupName="StirrupMode" Content="Đều suốt nhịp"
                                     Foreground="{DynamicResource Brush.Text}" VerticalAlignment="Center"
                                     IsChecked="{Binding StirrupUniform}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="20,2">
                        <TextBlock Text="A1:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding StirrupSpacingEnd}"/>
                        <TextBlock Text="L:" Style="{StaticResource FieldLabel}" Margin="8,0,0,0"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding StirrupUniformLength}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <RadioButton GroupName="StirrupMode" Content="Dày 2 đầu, thưa giữa"
                                     Foreground="{DynamicResource Brush.Text}" VerticalAlignment="Center"
                                     IsChecked="{Binding IsTwoEnds}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="20,2">
                        <TextBlock Text="A1:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding StirrupSpacingEnd}"/>
                        <TextBlock Text="A2:" Style="{StaticResource FieldLabel}" Margin="8,0,0,0"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding StirrupSpacingMid}"/>
                    </StackPanel>

                    <TextBlock Text="12. THÉP CHỐNG PHÌNH (Anti-bulge)" Style="{StaticResource SectionHeader}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <CheckBox Style="{StaticResource Check}" IsChecked="{Binding AntiBulgeEnabled}"/>
                        <TextBlock Text="Bật khi h >" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding AntiBulgeThreshold}"/>
                        <TextBlock Text="mm" Style="{StaticResource FieldLabel}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="20,2">
                        <TextBlock Text="Đường kính:" Width="90" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding Diameters}" SelectedItem="{Binding AntiBulgeDiameter}"/>
                        <TextBlock Text="@" Style="{StaticResource FieldLabel}" Margin="6,0"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding AntiBulgeSpacing}"/>
                    </StackPanel>

                    <TextBlock Text="LỚP BẢO VỆ (Cover, mm)" Style="{StaticResource SectionHeader}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="Trên:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding CoverTop}"/>
                        <TextBlock Text="Dưới:" Style="{StaticResource FieldLabel}" Margin="8,0,0,0"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding CoverBottom}"/>
                        <TextBlock Text="Bên:" Style="{StaticResource FieldLabel}" Margin="8,0,0,0"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding CoverSide}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <TextBlock Grid.Row="1" Text="{Binding ValidationMessage}" TextWrapping="Wrap"
                   Foreground="{DynamicResource Brush.Danger}" Margin="0,8"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Create Rebars Immediately" Width="200" Height="30" Margin="0,0,8,0"
                    Background="{DynamicResource Brush.Accent}" Foreground="{DynamicResource Brush.Text}"
                    Command="{Binding CreateImmediatelyCommand}"/>
            <Button Content="Close" Width="90" Height="30"
                    Background="{DynamicResource Brush.Button}" Foreground="{DynamicResource Brush.Text}"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>
