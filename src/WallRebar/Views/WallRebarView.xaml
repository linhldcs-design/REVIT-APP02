<Window x:Class="WallRebar.Views.WallRebarView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WallRebar.Views"
        Title="Wall Rebar" Height="800" Width="1015"
        WindowStartupLocation="CenterOwner"
        Background="#FFF4F4F4"
        FontFamily="Segoe UI" FontSize="12">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WallRebar;component/Resources/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,4,0"/>
            </Style>
            <Style x:Key="NumBox" TargetType="TextBox">
                <Setter Property="Width" Value="78"/>
                <Setter Property="Height" Value="30"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style x:Key="SmallNumBox" TargetType="TextBox" BasedOn="{StaticResource NumBox}">
                <Setter Property="Width" Value="58"/>
            </Style>
            <Style x:Key="IconButton" TargetType="Button">
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="30"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#FFE00000"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style x:Key="WallGroup" TargetType="GroupBox">
                <Setter Property="Margin" Value="4"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="BorderBrush" Value="#FFB8B8B8"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="8">
        <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="LINH LE 0862896841" Foreground="#FFCC0000" FontSize="16"
                               FontWeight="SemiBold" Margin="8,0,18,0"/>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Width="500" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Create" Command="{Binding CreateCommand}" Width="100" Height="30" Margin="0,0,8,0"/>
                    <Button Content="Close" Command="{Binding CloseCommand}" Width="100" Height="30"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid DockPanel.Dock="Top" Height="110">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="365"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Configuration (Lưu / Tải cấu hình)" Style="{StaticResource WallGroup}" Grid.Column="0">
                <StackPanel Margin="10,6,8,6">
                    <!-- Hàng 1: chọn preset đã lưu -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Cấu hình đã lưu:" Width="92" VerticalAlignment="Center"/>
                        <ComboBox Width="160" Height="28"
                                  ToolTip="Chọn một cấu hình đã lưu để tải lại"
                                  ItemsSource="{Binding PresetNames}"
                                  SelectedItem="{Binding SelectedPreset}"/>
                        <Button Content="Xoá" Command="{Binding DeletePresetCommand}"
                                Width="48" Height="28" Margin="6,0,0,0"
                                ToolTip="Xoá cấu hình đang chọn"/>
                    </StackPanel>
                    <!-- Hàng 2: nhập tên + lưu -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Tên cấu hình:" Width="92" VerticalAlignment="Center"/>
                        <TextBox Width="160" Height="28" VerticalContentAlignment="Center"
                                 ToolTip="Nhập tên rồi bấm Lưu để lưu cấu hình hiện tại"
                                 Text="{Binding PresetNameInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Lưu" Command="{Binding SavePresetCommand}"
                                Width="48" Height="28" Margin="6,0,0,0"
                                ToolTip="Lưu cấu hình hiện tại theo tên đã nhập"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Cover Setting" Style="{StaticResource WallGroup}" Grid.Column="1">
                <Canvas Height="62">
                    <TextBlock Text="Top/Bottom:" Canvas.Left="28" Canvas.Top="25"/>
                    <TextBox Style="{StaticResource NumBox}" Canvas.Left="98" Canvas.Top="17" Text="{Binding CoverTopBottomMm}"/>
                    <TextBlock Text="mm" Canvas.Left="180" Canvas.Top="25"/>
                    <TextBlock Text="Left/Right:" Canvas.Left="230" Canvas.Top="25"/>
                    <TextBox Style="{StaticResource NumBox}" Canvas.Left="300" Canvas.Top="17" Text="{Binding CoverLeftRightMm}"/>
                    <TextBlock Text="mm" Canvas.Left="382" Canvas.Top="25"/>
                    <TextBlock Text="Start/End:" Canvas.Left="432" Canvas.Top="25"/>
                    <TextBox Style="{StaticResource NumBox}" Canvas.Left="498" Canvas.Top="17" Text="{Binding CoverStartEndMm}"/>
                    <TextBlock Text="mm" Canvas.Left="580" Canvas.Top="25"/>
                </Canvas>
            </GroupBox>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="365"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Cross Section" Style="{StaticResource WallGroup}" Grid.Column="0">
                <Canvas Width="352" Height="548">
                    <views:CrossSectionAnimation Canvas.Left="28" Canvas.Top="80" Width="148" Height="384"/>

                    <TextBlock Text="Hook Type:" Canvas.Left="12" Canvas.Top="34"/>
                    <ComboBox Width="86" Height="60" Canvas.Left="78" Canvas.Top="14"
                              ItemsSource="{Binding HookTypeOptions}" SelectedItem="{Binding TopHookType}"/>
                    <TextBlock Text="Hook Length:" Canvas.Left="166" Canvas.Top="34"/>
                    <TextBox Style="{StaticResource NumBox}" Width="70" Canvas.Left="238" Canvas.Top="27" Text="{Binding TopHookLengthMm}"/>
                    <TextBlock Text="mm" Canvas.Left="312" Canvas.Top="34"/>

                    <TextBlock Text="Top Offset:" Canvas.Left="184" Canvas.Top="88"/>
                    <TextBox Style="{StaticResource NumBox}" Width="70" Canvas.Left="248" Canvas.Top="80" Text="{Binding TopOffsetMm}"/>
                    <TextBlock Text="mm" Canvas.Left="322" Canvas.Top="88"/>

                    <TextBlock Text="D" Canvas.Left="150" Canvas.Top="250"/>
                    <ComboBox Width="72" Height="30" Canvas.Left="166" Canvas.Top="242"
                              ItemsSource="{Binding DiameterOptions}" SelectedItem="{Binding VerticalDiameterMm}"/>
                    <TextBlock Text="@" Canvas.Left="242" Canvas.Top="250"/>
                    <TextBox Style="{StaticResource NumBox}" Width="72" Canvas.Left="258" Canvas.Top="242" Text="{Binding VerticalSpacingMm}"/>
                    <TextBlock Text="mm" Canvas.Left="334" Canvas.Top="250"/>

                    <TextBlock Text="D" Canvas.Left="150" Canvas.Top="292"/>
                    <ComboBox Width="72" Height="30" Canvas.Left="166" Canvas.Top="284"
                              ItemsSource="{Binding DiameterOptions}" SelectedItem="{Binding HorizontalDiameterMm}"/>
                    <TextBlock Text="@" Canvas.Left="242" Canvas.Top="292"/>
                    <TextBox Style="{StaticResource NumBox}" Width="72" Canvas.Left="258" Canvas.Top="284" Text="{Binding HorizontalSpacingMm}"/>
                    <TextBlock Text="mm" Canvas.Left="334" Canvas.Top="292"/>

                    <TextBlock Text="D" Canvas.Left="150" Canvas.Top="334"/>
                    <ComboBox Width="72" Height="30" Canvas.Left="166" Canvas.Top="326"
                              ItemsSource="{Binding DiameterOptions}" SelectedItem="{Binding TieDiameterMm}"/>
                    <TextBlock Text="@" Canvas.Left="242" Canvas.Top="334"/>
                    <TextBox Style="{StaticResource NumBox}" Width="72" Canvas.Left="258" Canvas.Top="326" Text="{Binding TieSpacingMm}"/>
                    <TextBlock Text="mm" Canvas.Left="334" Canvas.Top="334"/>

                    <TextBlock Text="Bottom Offset:" Canvas.Left="168" Canvas.Top="422"/>
                    <TextBox Style="{StaticResource NumBox}" Width="72" Canvas.Left="252" Canvas.Top="414" Text="{Binding BottomOffsetMm}"/>
                    <TextBlock Text="mm" Canvas.Left="328" Canvas.Top="422"/>

                    <TextBlock Text="Hook Type:" Canvas.Left="12" Canvas.Top="494"/>
                    <ComboBox Width="86" Height="60" Canvas.Left="78" Canvas.Top="474"
                              ItemsSource="{Binding HookTypeOptions}" SelectedItem="{Binding BottomHookType}"/>
                    <TextBlock Text="Hook Length:" Canvas.Left="166" Canvas.Top="494"/>
                    <TextBox Style="{StaticResource NumBox}" Width="70" Canvas.Left="238" Canvas.Top="487" Text="{Binding BottomHookLengthMm}"/>
                    <TextBlock Text="mm" Canvas.Left="312" Canvas.Top="494"/>
                </Canvas>
            </GroupBox>

            <GroupBox Header="Longitudinal Section" Style="{StaticResource WallGroup}" Grid.Column="1">
                <Canvas Width="616" Height="548">
                    <TextBlock Text="Horizontal Offset Start:" Canvas.Left="62" Canvas.Top="72"/>
                    <TextBox Style="{StaticResource SmallNumBox}" Canvas.Left="190" Canvas.Top="64" Text="{Binding HorizontalOffsetStartMm}"/>
                    <TextBlock Text="mm" Canvas.Left="252" Canvas.Top="72"/>

                    <TextBlock Text="Horizontal Offset End:" Canvas.Left="390" Canvas.Top="72"/>
                    <TextBox Style="{StaticResource SmallNumBox}" Canvas.Left="512" Canvas.Top="64" Text="{Binding HorizontalOffsetEndMm}"/>
                    <TextBlock Text="mm" Canvas.Left="574" Canvas.Top="72"/>

                    <views:LongitudinalSectionAnimation Canvas.Left="8" Canvas.Top="102" Width="600" Height="350"/>

                    <CheckBox Content="Draw Additional Rebar"
                              IsChecked="{Binding DrawAdditionalRebar}"
                              Canvas.Left="66" Canvas.Top="466"/>
                    <CheckBox Content="Interior" Canvas.Left="260" Canvas.Top="466"
                              IsEnabled="{Binding DrawAdditionalRebar}"
                              IsChecked="{Binding DrawAdditionalRebarInterior}"/>
                    <CheckBox Content="Exterior" Canvas.Left="340" Canvas.Top="466"
                              IsEnabled="{Binding DrawAdditionalRebar}"
                              IsChecked="{Binding DrawAdditionalRebarExterior}"/>
                </Canvas>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
