<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Template 1 phương (X/Y) cho tab lưới: Diameter + radio Spacing/Number + checkbox Hook Length.
         DataContext = DirectionViewModel. Tiêu đề "X/Y Direction" đặt ngoài template (mỗi tab). -->
    <DataTemplate x:Key="DirectionTemplate">
        <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" Margin="4" Padding="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Diameter:" VerticalAlignment="Center" Width="80"
                               Foreground="{DynamicResource Brush.Foreground.Primary}"/>
                    <ComboBox MinWidth="90"
                              ItemsSource="{Binding DataContext.DiameterOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DiameterMm}"/>
                </StackPanel>

                <RadioButton Content="Rebar Spacing" IsChecked="{Binding UseSpacing}" Margin="0,2"/>
                <StackPanel Orientation="Horizontal" Margin="20,0,0,6" IsEnabled="{Binding UseSpacing}">
                    <TextBox Style="{DynamicResource NumberTextBox}" Text="{Binding SpacingMm}"/>
                    <TextBlock Text="(mm)" Style="{DynamicResource UnitLabel}"/>
                </StackPanel>

                <RadioButton Content="Rebar Number" IsChecked="{Binding UseNumber}" Margin="0,2"/>
                <StackPanel Orientation="Horizontal" Margin="20,0,0,6" IsEnabled="{Binding UseNumber}">
                    <TextBox Style="{DynamicResource NumberTextBox}" Text="{Binding Count}"/>
                </StackPanel>

                <CheckBox Content="Rebar Hook Length" IsChecked="{Binding HookEnabled}" Margin="0,4,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0" IsEnabled="{Binding HookEnabled}">
                    <TextBox Style="{DynamicResource NumberTextBox}" Text="{Binding HookLengthMm}"/>
                    <TextBlock Text="(mm)" Style="{DynamicResource UnitLabel}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!-- Spacing tokens (bội số 4). -->
    <Thickness x:Key="Spacing.Small">8</Thickness>
    <Thickness x:Key="Spacing.Medium">16</Thickness>
    <Thickness x:Key="Spacing.FieldGap">0,0,0,8</Thickness>

    <!-- Nhãn nhóm (group header xám đậm như "X Direction", "Cover Settings"). -->
    <Style x:Key="GroupHeader" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground.Primary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style x:Key="UnitLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground.Secondary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="6,0,0,0"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- TextBox số: căn phải như ảnh. -->
    <Style x:Key="NumberTextBox" TargetType="TextBox">
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="6,2,8,2"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="MinWidth" Value="80"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground.Primary}"/>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="20,6"/>
        <Setter Property="MinWidth" Value="90"/>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}"/>

    <Style x:Key="DiagramFrame" TargetType="Border">
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <DataTemplate x:Key="CommonDiagram">
        <Border Style="{StaticResource DiagramFrame}">
            <Canvas Width="250" Height="92">
                <Rectangle Canvas.Left="16" Canvas.Top="48" Width="140" Height="26" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Diagram.Concrete}"/>
                <Rectangle Canvas.Left="70" Canvas.Top="18" Width="34" Height="30" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Surface}"/>
                <Line X1="34" Y1="62" X2="138" Y2="62" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="86" Y1="22" X2="86" Y2="72" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Rectangle Canvas.Left="178" Canvas.Top="18" Width="54" Height="54" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Diagram.Concrete}"/>
                <Line X1="188" Y1="28" X2="222" Y2="62" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
            </Canvas>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="BottomDiagram">
        <Border Style="{StaticResource DiagramFrame}">
            <Canvas Width="250" Height="92">
                <Rectangle Canvas.Left="16" Canvas.Top="16" Width="72" Height="56" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Diagram.Concrete}"/>
                <Line X1="28" Y1="28" X2="76" Y2="28" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="28" Y1="44" X2="76" Y2="44" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="28" Y1="60" X2="76" Y2="60" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="34" Y1="24" X2="34" Y2="64" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="52" Y1="24" X2="52" Y2="64" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="70" Y1="24" X2="70" Y2="64" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Rectangle Canvas.Left="116" Canvas.Top="22" Width="116" Height="48" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Diagram.Concrete}"/>
                <Line X1="126" Y1="62" X2="222" Y2="62" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="3"/>
            </Canvas>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="TopDiagram">
        <Border Style="{StaticResource DiagramFrame}">
            <Canvas Width="250" Height="92">
                <Rectangle Canvas.Left="16" Canvas.Top="16" Width="72" Height="56" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Diagram.Concrete}"/>
                <Line X1="28" Y1="28" X2="76" Y2="28" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="28" Y1="44" X2="76" Y2="44" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="28" Y1="60" X2="76" Y2="60" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="34" Y1="24" X2="34" Y2="64" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="52" Y1="24" X2="52" Y2="64" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="70" Y1="24" X2="70" Y2="64" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Rectangle Canvas.Left="116" Canvas.Top="22" Width="116" Height="48" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Diagram.Concrete}"/>
                <Line X1="126" Y1="30" X2="222" Y2="30" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="3"/>
            </Canvas>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="MidDiagram">
        <Border Style="{StaticResource DiagramFrame}">
            <Canvas Width="250" Height="92">
                <Rectangle Canvas.Left="16" Canvas.Top="16" Width="72" Height="56" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Diagram.Concrete}"/>
                <Line X1="28" Y1="32" X2="76" Y2="32" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="28" Y1="56" X2="76" Y2="56" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="40" Y1="24" X2="40" Y2="64" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="64" Y1="24" X2="64" Y2="64" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Rectangle Canvas.Left="116" Canvas.Top="22" Width="116" Height="48" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Diagram.Concrete}"/>
                <Line X1="126" Y1="46" X2="222" Y2="46" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="3"/>
            </Canvas>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="VerticalDiagram">
        <Border Style="{StaticResource DiagramFrame}">
            <Canvas Width="250" Height="92">
                <Rectangle Canvas.Left="22" Canvas.Top="22" Width="66" Height="46" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Diagram.Concrete}"/>
                <Ellipse Canvas.Left="32" Canvas.Top="30" Width="7" Height="7" Fill="{DynamicResource Brush.Diagram.Rebar}"/>
                <Ellipse Canvas.Left="70" Canvas.Top="30" Width="7" Height="7" Fill="{DynamicResource Brush.Diagram.Rebar}"/>
                <Ellipse Canvas.Left="32" Canvas.Top="54" Width="7" Height="7" Fill="{DynamicResource Brush.Diagram.Rebar}"/>
                <Ellipse Canvas.Left="70" Canvas.Top="54" Width="7" Height="7" Fill="{DynamicResource Brush.Diagram.Rebar}"/>
                <Rectangle Canvas.Left="124" Canvas.Top="50" Width="106" Height="22" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Diagram.Concrete}"/>
                <Rectangle Canvas.Left="160" Canvas.Top="18" Width="34" Height="32" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Surface}"/>
                <Line X1="168" Y1="18" X2="168" Y2="70" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="3"/>
                <Line X1="186" Y1="18" X2="186" Y2="70" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="3"/>
            </Canvas>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="HorizontalDiagram">
        <Border Style="{StaticResource DiagramFrame}">
            <Canvas Width="250" Height="92">
                <Rectangle Canvas.Left="22" Canvas.Top="20" Width="68" Height="48" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Diagram.Concrete}"/>
                <Rectangle Canvas.Left="34" Canvas.Top="30" Width="44" Height="28" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Rectangle Canvas.Left="124" Canvas.Top="50" Width="106" Height="22" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Diagram.Concrete}"/>
                <Rectangle Canvas.Left="160" Canvas.Top="18" Width="34" Height="32" Stroke="{DynamicResource Brush.Border}" Fill="{DynamicResource Brush.Surface}"/>
                <Line X1="154" Y1="28" X2="200" Y2="28" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="154" Y1="40" X2="200" Y2="40" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
                <Line X1="154" Y1="52" X2="200" Y2="52" Stroke="{DynamicResource Brush.Diagram.Rebar}" StrokeThickness="2"/>
            </Canvas>
        </Border>
    </DataTemplate>

</ResourceDictionary>
