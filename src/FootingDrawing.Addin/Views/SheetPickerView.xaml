<Window x:Class="FootingDrawing.Addin.Views.SheetPickerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chọn Sheet đích" Height="420" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        FontSize="12">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FootingDrawing.Addin;component/Resources/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Chọn sheet để xuất bản vẽ vào:"
                   Foreground="{DynamicResource Brush.Foreground.Primary}" Margin="0,0,0,8"/>

        <ListBox Grid.Row="1" x:Name="SheetList"
                 Background="{DynamicResource Brush.Surface}"
                 Foreground="{DynamicResource Brush.Foreground.Primary}"
                 BorderBrush="{DynamicResource Brush.Border}"
                 MouseDoubleClick="OnDoubleClick"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Chọn" Width="90" Style="{DynamicResource PrimaryButton}" Click="OnOk"/>
            <Button Content="Huỷ" Width="90" Margin="8,0,0,0" Style="{DynamicResource SecondaryButton}" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
