<Window x:Class="FootingDrawing.Addin.Views.FootingDrawingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bản Vẽ Mặt Bằng Thép Móng" Height="620" Width="820"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        FontSize="12">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FootingDrawing.Addin;component/Resources/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="Row" TargetType="ComboBox">
                <Setter Property="Height" Value="26"/>
                <Setter Property="Margin" Value="0,3"/>
            </Style>
            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground.Primary}"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground.Primary}"/>
                <Setter Property="Margin" Value="0,3"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground.Primary}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== Cột trái: danh sách setting ===== -->
        <DockPanel Grid.Column="0" Grid.Row="0" Margin="0,0,10,0">
            <TextBlock DockPanel.Dock="Top" Text="Danh sách Setting" Style="{DynamicResource SectionHeader}"/>
            <Grid DockPanel.Dock="Bottom" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Add" Command="{Binding AddSettingCommand}" Style="{DynamicResource SecondaryButton}"/>
                <Button Grid.Column="1" Content="Update" Margin="4,0" Command="{Binding UpdateSettingCommand}" Style="{DynamicResource SecondaryButton}"/>
                <Button Grid.Column="2" Content="Delete" Command="{Binding DeleteSettingCommand}" Style="{DynamicResource SecondaryButton}"/>
            </Grid>
            <Grid DockPanel.Dock="Bottom" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Import" Command="{Binding ImportSettingCommand}" Style="{DynamicResource SecondaryButton}"/>
                <Button Grid.Column="1" Content="Export" Margin="4,0,0,0" Command="{Binding ExportSettingCommand}" Style="{DynamicResource SecondaryButton}"/>
            </Grid>
            <ListBox ItemsSource="{Binding Settings}" SelectedItem="{Binding SelectedSetting}"
                     DisplayMemberPath="Name"
                     Background="{DynamicResource Brush.Surface}"
                     Foreground="{DynamicResource Brush.Foreground.Primary}"
                     BorderBrush="{DynamicResource Brush.Border}" Margin="0,6"/>
        </DockPanel>

        <!-- ===== Cột phải: form cấu hình ===== -->
        <ScrollViewer Grid.Column="1" Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Tên Setting" Style="{DynamicResource FieldLabel}"/>
                <TextBox Text="{Binding SettingName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource NumberTextBox}" Height="26"/>

                <TextBlock Text="Loại Dimension" Style="{DynamicResource FieldLabel}" Margin="0,8,0,0"/>
                <ComboBox Style="{DynamicResource Row}" ItemsSource="{Binding Resources.DimensionTypes}" SelectedItem="{Binding DimensionType}"/>

                <TextBlock Text="Tag thép móng (lưới)" Style="{DynamicResource FieldLabel}" Margin="0,8,0,0"/>
                <CheckBox Content="Bật tag thép móng" IsChecked="{Binding FootingTagEnabled}"/>
                <ComboBox Style="{DynamicResource Row}" ItemsSource="{Binding Resources.RebarTagTypes}" SelectedItem="{Binding FootingRebarTag}"/>

                <TextBlock Text="Rebar Bending Detail" Style="{DynamicResource FieldLabel}" Margin="0,8,0,0"/>
                <CheckBox Content="Bật bending detail" IsChecked="{Binding BendingDetailEnabled}"/>
                <ComboBox Style="{DynamicResource Row}" ItemsSource="{Binding Resources.BendingDetailTypes}" SelectedItem="{Binding BendingDetailType}"/>

                <TextBlock Text="Dimension (tùy chọn từng lớp)" Style="{DynamicResource SectionHeader}" Margin="0,10,0,0"/>
                <CheckBox Content="DIM bao" IsChecked="{Binding DimOverallEnabled}"/>
                <CheckBox Content="DIM đế móng" IsChecked="{Binding DimBaseEnabled}"/>
                <CheckBox Content="DIM cổ móng" IsChecked="{Binding DimPedestalEnabled}"/>

                <TextBlock Text="Parent Plan View" Style="{DynamicResource FieldLabel}" Margin="0,8,0,0"/>
                <ComboBox Style="{DynamicResource Row}" ItemsSource="{Binding Resources.ParentPlanViews}" SelectedItem="{Binding ParentPlanView}"/>

                <TextBlock Text="Callout Type (Detail)" Style="{DynamicResource FieldLabel}" Margin="0,8,0,0"/>
                <ComboBox Style="{DynamicResource Row}" ItemsSource="{Binding Resources.CalloutTypes}" SelectedItem="{Binding CalloutType}"/>

                <TextBlock Text="View Template (Detail)" Style="{DynamicResource FieldLabel}" Margin="0,8,0,0"/>
                <ComboBox Style="{DynamicResource Row}" ItemsSource="{Binding Resources.ViewTemplates}" SelectedItem="{Binding ViewTemplate}"/>

                <TextBlock Text="Viewport Type" Style="{DynamicResource FieldLabel}" Margin="0,8,0,0"/>
                <ComboBox Style="{DynamicResource Row}" ItemsSource="{Binding Resources.ViewportTypes}" SelectedItem="{Binding ViewportType}"/>

                <TextBlock Text="Sheet đích" Style="{DynamicResource SectionHeader}" Margin="0,10,0,0"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding SheetNumber}" Style="{DynamicResource NumberTextBox}" Height="26"/>
                    <Button Grid.Column="1" Content="🔍" Width="34" Margin="4,0,0,0" Command="{Binding PickSheetCommand}" Style="{DynamicResource SecondaryButton}"/>
                </Grid>
                <TextBlock Text="{Binding SheetName}" Foreground="{DynamicResource Brush.Foreground.Secondary}" Margin="0,2,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <CheckBox Content="Ghi tiêu đề bản vẽ" IsChecked="{Binding TitleEnabled}"/>
                    <TextBlock Text="{Binding ScaleLabel}" Margin="20,0,0,0" FontWeight="Bold"/>
                </StackPanel>

                <TextBlock Text="{Binding ValidationMessage}" Foreground="{DynamicResource Brush.Accent}" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ===== Nút OK/Cancel ===== -->
        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Tạo bản vẽ" Width="120" Command="{Binding OkCommand}" Style="{DynamicResource PrimaryButton}"/>
            <Button Content="Huỷ" Width="90" Margin="8,0,0,0" Command="{Binding CancelCommand}" Style="{DynamicResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
